# Syndication secrets for `npm run syndicate` (POSSE step).
# Copy to .env and fill in. .env is gitignored; this template is committed.

# Canonical site origin. No trailing slash. Syndicated links point here, so
# this must match the deployed site (the post must be LIVE before syndicating).
SITE_URL=https://postliterate.org

# Mastodon (self-hosted instance). No trailing slash on the instance URL.
# Token: instance → Preferences → Development → New application
# (scopes: write:statuses is enough). Copy "Your access token".
MASTODON_INSTANCE=https://saturation.social
MASTODON_ACCESS_TOKEN=

# Bluesky (AT Protocol). Use an APP PASSWORD, never your main password.
# Create one: Settings → Privacy and Security → App Passwords → Add App Password.
# Identifier is your handle (e.g. you.bsky.social) or account email.
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=
