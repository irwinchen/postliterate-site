---
import { Settings, X, Sun, Moon, Compass, BookOpen } from '@lucide/astro';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Post-Literate" } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts: Outfit (sans), Literata (serif), Sono (mono) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Literata:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Outfit:wght@400;500;600&family=Sono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title} | Post-Literate</title>
    <Analytics />

    <!-- Theme initialization (prevent flash) -->
    <script is:inline>
      (function initTheme() {
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', savedTheme);
      })();
    </script>

    <style is:inline>
      a, button, [role="switch"] { cursor: pointer; }
      button svg, a svg { pointer-events: none; }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/" class="site-header-content">Post-Literate</a>
        <a href="/about" class="site-nav-link">About</a>
        <a href="/colophon" class="site-nav-link">Colophon</a>
        <a href="/rss.xml" class="site-nav-link">RSS</a>
      </nav>
      <button class="settings-toggle" aria-label="Settings" aria-expanded="false">
        <Settings size={20} stroke-width={1.5} />
      </button>
    </header>

    <div class="settings-overlay" hidden>
      <div class="settings-backdrop"></div>
      <div class="settings-panel">
        <div class="settings-panel-header">
          <span class="settings-panel-title">Settings</span>
          <button class="settings-close" aria-label="Close settings">
            <X size={18} />
          </button>
        </div>
        <div class="settings-row settings-row-centered">
          <span class="settings-label">Light <Sun size={16} /></span>
          <button class="settings-switch" data-setting="theme" role="switch" aria-checked="false">
            <span class="settings-switch-thumb"></span>
          </button>
          <span class="settings-label"><Moon size={16} /> Dark</span>
        </div>
        <div class="settings-row settings-row-centered" id="focus-reading-setting" hidden>
          <span class="settings-label">Browse <Compass size={16} /></span>
          <button class="settings-switch" data-setting="focus" role="switch" aria-checked="false">
            <span class="settings-switch-thumb"></span>
          </button>
          <span class="settings-label"><BookOpen size={16} /> Deep Reading</span>
        </div>
      </div>
    </div>
    </header>

    <slot />

    <footer class="site-footer">
      <span class="site-footer-content">&copy; {new Date().getFullYear()} Irwin Chen</span>
    </footer>

    <script is:inline>
      (function initSettings() {
        var toggle = document.querySelector('.settings-toggle');
        var overlay = document.querySelector('.settings-overlay');
        var backdrop = document.querySelector('.settings-backdrop');
        var closeBtn = document.querySelector('.settings-close');
        var themeSwitch = document.querySelector('[data-setting="theme"]');
        var focusSwitch = document.querySelector('[data-setting="focus"]');

        // Show focus reading toggle on blog post pages
        var focusRow = document.getElementById('focus-reading-setting');
        if (focusRow && document.querySelector('[data-deep-reading]')) {
          focusRow.removeAttribute('hidden');
        }

        // Sync dark mode switch state on load
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        themeSwitch.setAttribute('aria-checked', isDark ? 'true' : 'false');

        // Sync focus reading switch state on load
        var focusOn = localStorage.getItem('focusReading') !== 'false';
        focusSwitch.setAttribute('aria-checked', focusOn ? 'true' : 'false');

        function openSettings() {
          overlay.removeAttribute('hidden');
          toggle.setAttribute('aria-expanded', 'true');
        }

        function closeSettings() {
          overlay.setAttribute('hidden', '');
          toggle.setAttribute('aria-expanded', 'false');
        }

        // Open modal
        toggle.addEventListener('click', function() {
          var expanded = toggle.getAttribute('aria-expanded') === 'true';
          if (expanded) { closeSettings(); } else { openSettings(); }
        });

        // Close on backdrop click or close button
        backdrop.addEventListener('click', closeSettings);
        closeBtn.addEventListener('click', closeSettings);

        // Close on Escape
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && !overlay.hasAttribute('hidden')) {
            closeSettings();
          }
        });

        // Dark mode switch
        themeSwitch.addEventListener('click', function() {
          var current = document.documentElement.getAttribute('data-theme');
          var next = current === 'light' ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
          themeSwitch.setAttribute('aria-checked', next === 'dark' ? 'true' : 'false');
        });

        // Focus reading switch
        focusSwitch.addEventListener('click', function() {
          var isOn = focusSwitch.getAttribute('aria-checked') === 'true';
          var next = !isOn;
          focusSwitch.setAttribute('aria-checked', next ? 'true' : 'false');
          localStorage.setItem('focusReading', next ? 'true' : 'false');
          window.dispatchEvent(new CustomEvent('focusReadingChanged', { detail: { enabled: next } }));
        });
      })();
    </script>

    <!-- Lightbox overlay -->
    <div class="lightbox" id="lightbox" aria-hidden="true">
      <div class="lightbox-backdrop"></div>
      <button class="lightbox-close" aria-label="Close">
        <X size={20} />
      </button>
      <div class="lightbox-content">
        <img id="lightbox-img" src="" alt="" />
        <div class="lightbox-caption" id="lightbox-caption"></div>
      </div>
    </div>

    <script is:inline>
      (function initLightbox() {
        var lightbox = document.getElementById('lightbox');
        var lbImg = document.getElementById('lightbox-img');
        var lbCaption = document.getElementById('lightbox-caption');
        var closeBtn = lightbox.querySelector('.lightbox-close');
        var backdrop = lightbox.querySelector('.lightbox-backdrop');

        function open(src, alt, caption) {
          lbImg.src = src;
          lbImg.alt = alt || '';
          if (caption) {
            lbCaption.textContent = caption;
            lbCaption.style.display = '';
          } else {
            lbCaption.textContent = '';
            lbCaption.style.display = 'none';
          }
          lightbox.classList.add('active');
          lightbox.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        }

        function close() {
          lightbox.classList.remove('active');
          lightbox.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        }

        // Click on figure content to open
        document.addEventListener('click', function(e) {
          var figContent = e.target.closest('[data-lightbox] .figure-content');
          if (!figContent) return;
          var media = figContent.querySelector('img, video');
          if (!media) return;
          // Don't lightbox videos — let them play natively
          if (media.tagName === 'VIDEO') return;
          var figure = figContent.closest('[data-lightbox]');
          var caption = figure ? figure.querySelector('.figure-caption') : null;
          open(media.src || media.currentSrc, media.alt, caption ? caption.textContent : null);
        });

        closeBtn.addEventListener('click', close);
        backdrop.addEventListener('click', close);
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && lightbox.classList.contains('active')) {
            close();
          }
        });
      })();
    </script>

    <script is:inline>
      (function initFocusReader() {
        var content = document.querySelector('[data-deep-reading]');
        if (!content) return;

        var elements = Array.prototype.slice.call(content.children).filter(function(el) {
          return !el.classList.contains('end-mark');
        });
        var endMark = content.querySelector('.end-mark');
        if (elements.length === 0) return;

        var visibleCount = 0;
        var enabled = false;

        var advanceBtn = document.createElement('button');
        advanceBtn.className = 'fr-advance';
        advanceBtn.setAttribute('aria-label', 'Show next section');
        advanceBtn.innerHTML = '<svg width="48" height="48" viewBox="0 0 48 48"><circle cx="24" cy="24" r="20" fill="none" stroke="var(--border-subtle)" stroke-width="4" opacity="0.3"/><circle class="fr-progress-ring" cx="24" cy="24" r="20" fill="none" stroke="var(--accent)" stroke-width="4" stroke-linecap="round" stroke-dasharray="125.66" stroke-dashoffset="125.66" transform="rotate(-90 24 24)"/><path d="M18 21l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        advanceBtn.style.display = 'none';
        content.parentNode.insertBefore(advanceBtn, content.nextSibling);

        var fullscreenBtn = document.createElement('button');
        fullscreenBtn.className = 'fr-fullscreen';
        fullscreenBtn.setAttribute('aria-label', 'Toggle fullscreen');
        var expandIcon = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/></svg>';
        var collapseIcon = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14h6v6"/><path d="M20 10h-6V4"/><path d="M14 10l7-7"/><path d="M3 21l7-7"/></svg>';
        fullscreenBtn.innerHTML = expandIcon;
        fullscreenBtn.style.display = 'none';
        content.parentNode.insertBefore(fullscreenBtn, content.nextSibling);

        fullscreenBtn.addEventListener('click', function() {
          if (document.fullscreenElement) {
            document.exitFullscreen();
          } else {
            document.documentElement.requestFullscreen();
          }
        });

        document.addEventListener('fullscreenchange', function() {
          fullscreenBtn.innerHTML = document.fullscreenElement ? collapseIcon : expandIcon;
        });

        var circumference = 2 * Math.PI * 20;
        var progressRing = advanceBtn.querySelector('.fr-progress-ring');

        function updateProgress() {
          if (!progressRing) return;
          var progress = visibleCount / elements.length;
          progressRing.style.strokeDashoffset = circumference * (1 - progress);
        }

        function pulseRing() {
          if (!progressRing) return;
          progressRing.style.transition = 'none';
          progressRing.style.strokeDashoffset = circumference;
          progressRing.getBoundingClientRect();
          progressRing.style.transition = 'stroke-dashoffset 0.4s ease';
          updateProgress();
        }

        function enableFocusReading() {
          enabled = true;
          document.body.classList.add('fr-active');
          visibleCount = 1;
          for (var i = 0; i < elements.length; i++) {
            if (i === 0) {
              elements[i].classList.remove('fr-hidden', 'fr-revealing', 'fr-visible');
            } else {
              elements[i].classList.remove('fr-revealing', 'fr-visible');
              elements[i].classList.add('fr-hidden');
            }
          }
          if (endMark) endMark.classList.remove('fr-revealed');
          content.style.paddingBottom = '50vh';
          advanceBtn.style.display = elements.length > 1 ? '' : 'none';
          fullscreenBtn.style.display = '';
          setTimeout(pulseRing, 500);
        }

        function disableFocusReading() {
          enabled = false;
          document.body.classList.remove('fr-active');
          visibleCount = 0;
          for (var i = 0; i < elements.length; i++) {
            elements[i].classList.remove('fr-hidden', 'fr-revealing', 'fr-visible');
          }
          if (endMark) endMark.classList.remove('fr-revealed');
          content.style.paddingBottom = '';
          advanceBtn.style.display = 'none';
          fullscreenBtn.style.display = 'none';
          if (document.fullscreenElement) document.exitFullscreen();
        }

        function advanceContent() {
          if (!enabled || visibleCount >= elements.length) return;
          // Dim the previous element
          var prev = elements[visibleCount - 1];
          if (prev) prev.classList.add('fr-visible');

          var el = elements[visibleCount];
          el.classList.remove('fr-hidden');
          el.classList.add('fr-revealing');

          var isFigure = el.classList.contains('figure');
          var cleaned = false;
          function cleanup() {
            if (cleaned) return;
            cleaned = true;
            el.classList.remove('fr-revealing');
            el.style.clipPath = '';
            el.style.opacity = '';
            el.style.transition = '';
          }

          if (isFigure) {
            // Simple fade-in for figures
            el.style.opacity = '0';
            el.style.transition = 'opacity 0.6s ease';
            void el.offsetWidth;
            el.style.opacity = '1';
            setTimeout(cleanup, 700);
          } else {
            // Line-by-line typewriter reveal via clip-path polygon
            var style = getComputedStyle(el);
            var lh = parseFloat(style.lineHeight);
            if (isNaN(lh)) lh = parseFloat(style.fontSize) * 1.4;
            var totalH = el.scrollHeight;
            var lines = Math.max(1, Math.round(totalH / lh));
            var perLine = 1.5 / lines;
            if (perLine < 0.12) perLine = 0.12;
            var totalDur = perLine * lines * 1000;
            var line = 0;
            var lineStart = performance.now();

            el.style.clipPath = 'polygon(0 0, 0 0, 0 ' + lh + 'px, 0 ' + lh + 'px)';

            function frame(now) {
              if (cleaned) return;
              var t = Math.min((now - lineStart) / (perLine * 1000), 1);
              var x = (t * 100) + '%';
              var top = (line * lh) + 'px';
              var bottom = Math.min((line + 1) * lh, totalH) + 'px';

              if (line === 0) {
                el.style.clipPath = 'polygon(0 0, ' + x + ' 0, ' + x + ' ' + bottom + ', 0 ' + bottom + ')';
              } else {
                el.style.clipPath = 'polygon(0 0, 100% 0, 100% ' + top + ', ' + x + ' ' + top + ', ' + x + ' ' + bottom + ', 0 ' + bottom + ')';
              }

              if (t < 1) {
                requestAnimationFrame(frame);
              } else {
                line++;
                if (line < lines) {
                  lineStart = performance.now();
                  requestAnimationFrame(frame);
                } else {
                  cleanup();
                }
              }
            }

            requestAnimationFrame(frame);
            setTimeout(cleanup, totalDur + 200);
          }

          var rect = el.getBoundingClientRect();
          var scrollFrom = window.pageYOffset || document.documentElement.scrollTop;
          var scrollTo = scrollFrom + rect.top - 80;
          smoothScroll(scrollFrom, scrollTo, 600);

          visibleCount++;
          updateProgress();
          if (visibleCount >= elements.length) {
            advanceBtn.style.display = 'none';
            if (endMark) {
              endMark.classList.add('fr-revealed', 'fr-revealing');
            }
          }
        }

        function smoothScroll(from, to, duration) {
          var start = performance.now();
          var diff = to - from;
          function step(now) {
            var t = Math.min((now - start) / duration, 1);
            var ease = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
            window.scrollTo(0, from + diff * ease);
            if (t < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        }

        advanceBtn.addEventListener('click', advanceContent);

        document.addEventListener('keydown', function(e) {
          if (!enabled) return;
          var tag = (e.target.tagName || '').toLowerCase();
          if (tag === 'input' || tag === 'textarea' || tag === 'select' || e.target.isContentEditable) return;
          if (e.key === 'ArrowDown' || e.key === ' ' || e.key === 'j') {
            e.preventDefault();
            advanceContent();
          }
        });

        window.addEventListener('focusReadingChanged', function(e) {
          if (e.detail.enabled) {
            enableFocusReading();
          } else {
            disableFocusReading();
          }
        });

        if (localStorage.getItem('focusReading') !== 'false') {
          enableFocusReading();
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
