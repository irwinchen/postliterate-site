---
import { Settings, X, Sun, Moon, Compass, BookOpen } from '@lucide/astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Post-Literate" } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts: Outfit (sans), Literata (serif), Sono (mono) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Literata:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Outfit:wght@400;500;600&family=Sono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title} | Post-Literate</title>

    <!-- Theme initialization (prevent flash) -->
    <script is:inline>
      (function initTheme() {
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', savedTheme);
      })();
    </script>

    <style is:inline>
      a, button, [role="switch"] { cursor: pointer; }
      button svg, a svg { pointer-events: none; }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/" class="site-header-content">Post-Literate</a>
        <a href="/about" class="site-nav-link">About</a>
      </nav>
      <button class="settings-toggle" aria-label="Settings" aria-expanded="false">
        <Settings size={20} stroke-width={1.5} />
      </button>
    </header>

    <div class="settings-overlay" hidden>
      <div class="settings-backdrop"></div>
      <div class="settings-panel">
        <div class="settings-panel-header">
          <span class="settings-panel-title">Settings</span>
          <button class="settings-close" aria-label="Close settings">
            <X size={18} />
          </button>
        </div>
        <div class="settings-row settings-row-centered">
          <span class="settings-label">Light <Sun size={16} /></span>
          <button class="settings-switch" data-setting="theme" role="switch" aria-checked="false">
            <span class="settings-switch-thumb"></span>
          </button>
          <span class="settings-label"><Moon size={16} /> Dark</span>
        </div>
        <div class="settings-row settings-row-centered" id="focus-reading-setting" hidden>
          <span class="settings-label">Browse <Compass size={16} /></span>
          <button class="settings-switch" data-setting="focus" role="switch" aria-checked="false">
            <span class="settings-switch-thumb"></span>
          </button>
          <span class="settings-label"><BookOpen size={16} /> Deep Reading</span>
        </div>
      </div>
    </div>
    </header>

    <slot />

    <footer class="site-footer">
      <span class="site-footer-content">&copy; {new Date().getFullYear()} Irwin Chen</span>
    </footer>

    <script is:inline>
      (function initSettings() {
        var toggle = document.querySelector('.settings-toggle');
        var overlay = document.querySelector('.settings-overlay');
        var backdrop = document.querySelector('.settings-backdrop');
        var closeBtn = document.querySelector('.settings-close');
        var themeSwitch = document.querySelector('[data-setting="theme"]');
        var focusSwitch = document.querySelector('[data-setting="focus"]');

        // Show focus reading toggle on blog post pages
        var focusRow = document.getElementById('focus-reading-setting');
        if (focusRow && document.querySelector('.article-content')) {
          focusRow.removeAttribute('hidden');
        }

        // Sync dark mode switch state on load
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        themeSwitch.setAttribute('aria-checked', isDark ? 'true' : 'false');

        // Sync focus reading switch state on load
        var focusOn = localStorage.getItem('focusReading') !== 'false';
        focusSwitch.setAttribute('aria-checked', focusOn ? 'true' : 'false');

        function openSettings() {
          overlay.removeAttribute('hidden');
          toggle.setAttribute('aria-expanded', 'true');
        }

        function closeSettings() {
          overlay.setAttribute('hidden', '');
          toggle.setAttribute('aria-expanded', 'false');
        }

        // Open modal
        toggle.addEventListener('click', function() {
          var expanded = toggle.getAttribute('aria-expanded') === 'true';
          if (expanded) { closeSettings(); } else { openSettings(); }
        });

        // Close on backdrop click or close button
        backdrop.addEventListener('click', closeSettings);
        closeBtn.addEventListener('click', closeSettings);

        // Close on Escape
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && !overlay.hasAttribute('hidden')) {
            closeSettings();
          }
        });

        // Dark mode switch
        themeSwitch.addEventListener('click', function() {
          var current = document.documentElement.getAttribute('data-theme');
          var next = current === 'light' ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
          themeSwitch.setAttribute('aria-checked', next === 'dark' ? 'true' : 'false');
        });

        // Focus reading switch
        focusSwitch.addEventListener('click', function() {
          var isOn = focusSwitch.getAttribute('aria-checked') === 'true';
          var next = !isOn;
          focusSwitch.setAttribute('aria-checked', next ? 'true' : 'false');
          localStorage.setItem('focusReading', next ? 'true' : 'false');
          window.dispatchEvent(new CustomEvent('focusReadingChanged', { detail: { enabled: next } }));
        });
      })();
    </script>

    <script is:inline>
      (function initFocusReader() {
        var content = document.querySelector('.article-content');
        if (!content) return;

        var elements = Array.prototype.slice.call(content.children);
        if (elements.length === 0) return;

        var visibleCount = 0;
        var enabled = false;

        var advanceBtn = document.createElement('button');
        advanceBtn.className = 'fr-advance';
        advanceBtn.setAttribute('aria-label', 'Show next section');
        advanceBtn.innerHTML = '<svg width="48" height="48" viewBox="0 0 48 48"><circle cx="24" cy="24" r="20" fill="none" stroke="var(--border-subtle)" stroke-width="4" opacity="0.3"/><circle class="fr-progress-ring" cx="24" cy="24" r="20" fill="none" stroke="var(--accent)" stroke-width="4" stroke-linecap="round" stroke-dasharray="125.66" stroke-dashoffset="125.66" transform="rotate(-90 24 24)"/><path d="M18 21l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        advanceBtn.style.display = 'none';
        content.parentNode.insertBefore(advanceBtn, content.nextSibling);

        var circumference = 2 * Math.PI * 20;
        var progressRing = advanceBtn.querySelector('.fr-progress-ring');

        function updateProgress() {
          if (!progressRing) return;
          var progress = visibleCount / elements.length;
          progressRing.style.strokeDashoffset = circumference * (1 - progress);
        }

        function enableFocusReading() {
          enabled = true;
          visibleCount = 1;
          for (var i = 0; i < elements.length; i++) {
            if (i === 0) {
              elements[i].classList.remove('fr-hidden', 'fr-revealing', 'fr-visible');
            } else {
              elements[i].classList.remove('fr-revealing', 'fr-visible');
              elements[i].classList.add('fr-hidden');
            }
          }
          content.style.paddingBottom = '50vh';
          advanceBtn.style.display = elements.length > 1 ? '' : 'none';
          updateProgress();
        }

        function disableFocusReading() {
          enabled = false;
          visibleCount = 0;
          for (var i = 0; i < elements.length; i++) {
            elements[i].classList.remove('fr-hidden', 'fr-revealing', 'fr-visible');
          }
          content.style.paddingBottom = '';
          advanceBtn.style.display = 'none';
        }

        function advanceContent() {
          if (!enabled || visibleCount >= elements.length) return;
          // Dim the previous element
          var prev = elements[visibleCount - 1];
          if (prev) prev.classList.add('fr-visible');

          var el = elements[visibleCount];
          el.classList.remove('fr-hidden');
          el.classList.add('fr-revealing');

          var cleaned = false;
          function cleanup() {
            if (cleaned) return;
            cleaned = true;
            el.classList.remove('fr-revealing');
          }

          el.addEventListener('animationend', cleanup, { once: true });
          setTimeout(cleanup, 900);

          var rect = el.getBoundingClientRect();
          var scrollFrom = window.pageYOffset || document.documentElement.scrollTop;
          var scrollTo = scrollFrom + rect.top - window.innerHeight * 0.33;
          smoothScroll(scrollFrom, scrollTo, 600);

          visibleCount++;
          updateProgress();
          if (visibleCount >= elements.length) {
            advanceBtn.style.display = 'none';
          }
        }

        function smoothScroll(from, to, duration) {
          var start = performance.now();
          var diff = to - from;
          function step(now) {
            var t = Math.min((now - start) / duration, 1);
            var ease = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
            window.scrollTo(0, from + diff * ease);
            if (t < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        }

        advanceBtn.addEventListener('click', advanceContent);

        document.addEventListener('keydown', function(e) {
          if (!enabled) return;
          var tag = (e.target.tagName || '').toLowerCase();
          if (tag === 'input' || tag === 'textarea' || tag === 'select' || e.target.isContentEditable) return;
          if (e.key === 'ArrowDown' || e.key === ' ' || e.key === 'j') {
            e.preventDefault();
            advanceContent();
          }
        });

        window.addEventListener('focusReadingChanged', function(e) {
          if (e.detail.enabled) {
            enableFocusReading();
          } else {
            disableFocusReading();
          }
        });

        if (localStorage.getItem('focusReading') !== 'false') {
          enableFocusReading();
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
