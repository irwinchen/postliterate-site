---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { postSlug, smartQuotes } from '../utils';
import BlueskyFeed from '../components/BlueskyFeed.astro';

const posts = await getCollection('blog', ({ data }) => data.status === 'published');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function countWords(body: string | undefined) {
  return (body ?? '')
    .replace(/^import\s.*$/gm, '')
    .replace(/<[^>]+>/g, ' ')
    .replace(/[#*_~`>|[\]()]/g, '')
    .split(/\s+/)
    .filter((w) => w.length > 0).length;
}
---

<Base title="Post-Literate" description="Writing about orality, literacy, and AI.">
  <div class="page-container has-sidebar">
    <main class="main-column">
      <header class="article-header">
        <h1 class="article-title">Post-Literate</h1>
        <p class="subtitle">Notes on reading and orality in the age of AI</p>

      </header>

      {sortedPosts.length === 0 ? (
        <p style="color: var(--text-secondary); font-style: italic;">No posts yet.</p>
      ) : (
        <ul class="post-list">
          {sortedPosts.map((post) => (
            <li class="post-item" data-tags={(post.data.tags ?? []).join(',')}>
              <a href={`/blog/${postSlug(post.id)}`} class="post-link">
                <div class="post-title">{smartQuotes(post.data.title)}</div>
                <div class="post-date">
                  {post.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                  {' · '}
                  {countWords(post.body).toLocaleString()} words
                </div>
                {post.data.description && (
                  <div class="post-description">{post.data.description}</div>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}
    </main>
    <BlueskyFeed handle="tmonkey718.bsky.social" limit={10} />
  </div>

  <script is:inline>
    (function initScrollFade() {
      var timers = new WeakMap();
      document.querySelectorAll('.has-sidebar .main-column, .has-sidebar .bsky-feed').forEach(function(el) {
        el.addEventListener('scroll', function() {
          el.classList.add('is-scrolling');
          clearTimeout(timers.get(el));
          timers.set(el, setTimeout(function() {
            el.classList.remove('is-scrolling');
          }, 1200));
        }, { passive: true });
      });
    })();

    (function initBskyLinks() {
      document.querySelectorAll('.bsky-post[data-href]').forEach(function(post) {
        post.addEventListener('click', function(e) {
          if (e.target.closest('a')) return;
          window.open(post.dataset.href, '_blank', 'noopener');
        });
      });
    })();
  </script>
</Base>
