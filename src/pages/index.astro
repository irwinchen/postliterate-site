---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { postSlug, smartQuotes } from '../utils';

const posts = await getCollection('blog', ({ data }) => data.status === 'published');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postsByYear = sortedPosts.reduce(
  (groups: Record<number, typeof sortedPosts>, post) => {
    const year = post.data.date.getFullYear();
    if (!groups[year]) groups[year] = [];
    groups[year].push(post);
    return groups;
  },
  {}
);
const years = Object.keys(postsByYear).map(Number).sort((a, b) => b - a);
---

<Base title="Post-Literate" description="Writing about orality, literacy, and AI." hideHeader={true}>
  <div class="page-container home-page">
    <main class="main-column">
      <header class="home-header">
        <img
          src="/images/virgil_icon.svg"
          class="home-owl"
          alt="Virgil"
          width="52"
          height="52"
        />
        <h1 class="article-title">Post-Literate</h1>
        <p class="subtitle">Notes on reading and orality in the age of AI</p>
        <nav class="home-nav" aria-label="Site navigation">
          <a href="/about" class="site-nav-link">About</a>
          <a href="/colophon" class="site-nav-link">Colophon</a>
          <a href="/rss.xml" class="site-nav-link">RSS</a>
        </nav>
      </header>

      {sortedPosts.length === 0 ? (
        <p style="color: var(--text-secondary); font-style: italic;">No posts yet.</p>
      ) : years.map((year) => (
        <div class="home-year-group">
          <h2 class="home-year-label">{year}</h2>
          <ul class="post-list home-post-list">
            {postsByYear[year].map((post) => (
              <li class="post-item home-post-item">
                <a href={`/blog/${postSlug(post.id)}`} class="post-link home-post-link">
                  <span class="home-date">
                    {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                  </span>
                  <span class="home-title">{smartQuotes(post.data.title)}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </main>
  </div>
</Base>

<style is:global>
  /* Homepage: narrower column, collapsed top grid row (no fixed header) */
  .home-page {
    --content-width: 62ch;
    grid-template-rows: 40px auto 80px;
  }

  .home-page .main-column {
    padding-block-start: 0;
  }

  /* Masthead section */
  .home-header {
    margin-block-end: calc(var(--line-height) * 2.5);
  }

  .home-owl {
    width: 52px;
    height: 52px;
    display: block;
    margin-block-end: calc(var(--line-height) * 0.6);
  }

  /* Inline nav below tagline */
  .home-nav {
    display: flex;
    gap: 1.5em;
    margin-block-start: calc(var(--line-height) * 0.75);
  }

  /* Year group */
  .home-year-group {
    margin-block-end: calc(var(--line-height) * 2);
  }

  .home-year-label {
    font-family: 'Outfit', sans-serif;
    font-size: var(--text-meta);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-block-end: 0;
    padding-block-end: calc(var(--line-height) * 0.35);
    border-block-end: 1px solid var(--accent);
  }

  /* Scoped under .home-page so these beat the generic .post-item / .post-link
     rules in global.css regardless of CSS bundle order (dev vs. build). */
  .home-page .home-post-list {
    list-style: none;
    padding: 0;
  }

  .home-page .home-post-item {
    margin-block: 0;
    padding-block-end: 0;
    border-block-end: none;
  }

  /* Two-column grid: narrow date | vertical-rule border | title.
     The title lives in its own column, so long titles wrap within it
     instead of intruding under the date. */
  .home-page .home-post-link {
    display: grid;
    grid-template-columns: 7ch 1fr;
    align-items: baseline;
    padding-block: calc(var(--line-height) * 0.25);
    color: var(--text);
    text-decoration: none;
    border-block-end: none;

    &:hover {
      border-block-end: none;
    }

    &:hover .home-title {
      color: var(--accent);
    }
  }

  .home-page .home-date {
    font-family: 'Outfit', sans-serif;
    font-size: var(--text-caption);
    color: var(--text-tertiary);
    text-align: end;
    padding-inline-end: 1.25em;
    font-style: normal;
    line-height: 1.3;
  }

  .home-page .home-title {
    font-family: 'Outfit', sans-serif;
    font-size: var(--text-h3);
    font-weight: 500;
    line-height: 1.3;
    color: var(--text);
    text-wrap: balance;
    transition: color 0.2s ease;
    padding-inline-start: 1.25em;
    border-inline-start: 1px solid var(--border-subtle);
  }
</style>
