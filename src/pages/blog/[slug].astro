---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { postSlug, smartQuotes, truncateDiffContext } from '../../utils';
import { existsSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: postSlug(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const slug = postSlug(post.id);

const wordCount = (post.body ?? '')
  .replace(/^import\s.*$/gm, '')
  .replace(/<[^>]+>/g, ' ')
  .replace(/[#*_~`>|[\]()]/g, '')
  .split(/\s+/)
  .filter((w: string) => w.length > 0).length;

// Edit history
const historyPath = join(process.cwd(), 'src/data/history', `${slug}.json`);
let history: { slug: string; edits: Array<{ date: string; summary?: string; diff: Array<{ type: string; text: string }> | null }> } | null = null;
if (existsSync(historyPath)) {
  history = JSON.parse(readFileSync(historyPath, 'utf8'));
}
const hasEdits = (history?.edits?.length ?? 0) > 1;

// Pre-compute truncated diffs in frontmatter to avoid TS generics in template
type DiffSeg = { type: 'context' | 'del' | 'add'; text: string };
type TruncatedSeg = { type: string; text: string };
const truncatedDiffs: TruncatedSeg[][] = (history?.edits ?? []).map((edit) => {
  if (!edit.diff) return [];
  return truncateDiffContext(edit.diff as DiffSeg[]);
});
---

<Base title={post.data.title} description={post.data.description}>
  <div class="page-container">
    <main class="main-column has-margin-notes">
      <article>
        <header class="article-header">
          <h1 class="article-title">{smartQuotes(post.data.title)}</h1>
          <div class="article-metadata">
            <span class="article-date">
              {post.data.date.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </span>
            <span>{wordCount.toLocaleString()} words</span>
          </div>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="article-tags">
              {post.data.tags.map((tag: string) => (
                <a href={`/blog/tag/${tag}`} class="tag">{tag}</a>
              ))}
            </div>
          )}
        </header>

        <div class="article-content" data-deep-reading>
          <Content />
          <div class="end-mark" aria-hidden="true">
            <img src="/images/virgil.svg" alt="" width="18" height="18" />
          </div>
        </div>

        {hasEdits && history && (
          <section class="edit-history">
            <details>
              <summary>Edit history &middot; {history.edits.length} revisions</summary>
              <ol class="edit-list">
                {history.edits.map((edit, i) => {
                  const dateStr = new Date(edit.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  });
                  if (i === 0) {
                    return (
                      <li class="edit-entry">
                        <span class="edit-date">{dateStr}</span>
                        <span class="edit-label">{edit.summary ?? 'Initial publication'}</span>
                      </li>
                    );
                  }
                  return (
                    <li class="edit-entry">
                      <details>
                        <summary class="edit-date">{dateStr}</summary>
                        <div class="edit-diff">
                          {truncatedDiffs[i].map((seg) => {
                            if (seg.type === 'del') return <del class="diff-del">{seg.text}</del>;
                            if (seg.type === 'add') return <ins class="diff-add">{seg.text}</ins>;
                            if (seg.type === 'ellipsis') return <span class="diff-ellipsis">{seg.text}</span>;
                            return <span class="diff-context">{seg.text}</span>;
                          })}
                        </div>
                      </details>
                    </li>
                  );
                })}
              </ol>
            </details>
          </section>
        )}
      </article>

      <aside class="margin-column loading" id="margin-column">
        <!-- Margin notes collected here by MarginNote component -->
      </aside>
    </main>
  </div>
</Base>

<script>
  // MARGIN NOTES POSITIONING
  function positionMarginNotes() {
    const marginColumn = document.querySelector('.margin-column');
    if (!marginColumn || window.innerWidth <= 640) return;

    const notes = marginColumn.querySelectorAll('.margin-note');
    const marginRect = marginColumn.getBoundingClientRect();

    let lastNoteBottom = 0;

    notes.forEach(note => {
      const noteEl = note as HTMLElement;
      const targetId = noteEl.dataset.for;
      const targetAnchor = document.querySelector(`.note-anchor[data-note-id="${targetId}"]`);

      if (targetAnchor) {
        const anchorRect = targetAnchor.getBoundingClientRect();
        const relativeTop = anchorRect.top - marginRect.top + marginColumn.scrollTop;

        let targetY = relativeTop;

        if (targetY < lastNoteBottom + 10) {
          targetY = lastNoteBottom + 15;
        }

        noteEl.style.top = `${targetY}px`;
        lastNoteBottom = targetY + noteEl.offsetHeight;

        noteEl.dataset.anchorId = targetId;
        noteEl.dataset.yPos = String(targetY);
      }
    });

    marginColumn.classList.remove('loading');
    marginColumn.classList.add('loaded');
  }

  // DESKTOP HOVER INTERACTIONS
  function initDesktopHover() {
    if (window.innerWidth <= 640) return;

    const notes = document.querySelectorAll('.margin-note');
    notes.forEach(note => {
      note.addEventListener('mouseenter', () => {
        const noteEl = note as HTMLElement;
        const anchorId = noteEl.dataset.for;
        const anchor = document.querySelector(`.note-anchor[data-note-id="${anchorId}"]`);
        if (anchor) anchor.classList.add('highlighted');
      });

      note.addEventListener('mouseleave', () => {
        const noteEl = note as HTMLElement;
        const anchorId = noteEl.dataset.for;
        const anchor = document.querySelector(`.note-anchor[data-note-id="${anchorId}"]`);
        if (anchor) anchor.classList.remove('highlighted');
      });
    });

    const anchors = document.querySelectorAll('.note-anchor');
    anchors.forEach(anchor => {
      anchor.addEventListener('mouseenter', () => {
        const anchorEl = anchor as HTMLElement;
        const noteId = anchorEl.dataset.noteId;
        const note = document.querySelector(`.margin-note[data-for="${noteId}"]`);
        if (note) note.classList.add('hovered');
      });

      anchor.addEventListener('mouseleave', () => {
        const anchorEl = anchor as HTMLElement;
        const noteId = anchorEl.dataset.noteId;
        const note = document.querySelector(`.margin-note[data-for="${noteId}"]`);
        if (note) note.classList.remove('hovered');
      });
    });
  }

  // TAP INTERACTIONS (mobile inline notes + tablet/touch margin notes)
  function initTap() {
    const anchors = document.querySelectorAll('.note-anchor');
    const isNarrow = window.innerWidth <= 640;

    anchors.forEach(anchor => {
      anchor.addEventListener('click', (e) => {
        e.stopPropagation();
        if (isNarrow) {
          // Mobile: toggle inline note
          anchor.classList.toggle('active');
        } else {
          // Desktop/tablet: toggle linked margin note
          const anchorEl = anchor as HTMLElement;
          const noteId = anchorEl.dataset.noteId;
          const note = document.querySelector(`.margin-note[data-for="${noteId}"]`);
          if (note) {
            const wasActive = note.classList.contains('touch-active');
            // Close all first
            document.querySelectorAll('.margin-note.touch-active').forEach(n => n.classList.remove('touch-active'));
            document.querySelectorAll('.note-anchor.highlighted').forEach(a => a.classList.remove('highlighted'));
            if (!wasActive) {
              note.classList.add('touch-active');
              anchor.classList.add('highlighted');
            }
          }
        }
      });
    });

    if (!isNarrow) {
      const notes = document.querySelectorAll('.margin-note');
      notes.forEach(note => {
        note.addEventListener('click', (e) => {
          e.stopPropagation();
          const noteEl = note as HTMLElement;
          const wasActive = noteEl.classList.contains('touch-active');
          document.querySelectorAll('.margin-note.touch-active').forEach(n => n.classList.remove('touch-active'));
          document.querySelectorAll('.note-anchor.highlighted').forEach(a => a.classList.remove('highlighted'));
          if (!wasActive) {
            noteEl.classList.add('touch-active');
            const anchorId = noteEl.dataset.for;
            const anchor = document.querySelector(`.note-anchor[data-note-id="${anchorId}"]`);
            if (anchor) anchor.classList.add('highlighted');
          }
        });
      });
    }

    // Tap outside to dismiss
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!target.closest('.note-anchor') && !target.closest('.margin-note')) {
        document.querySelectorAll('.note-anchor.active').forEach(a => a.classList.remove('active'));
        document.querySelectorAll('.note-anchor.highlighted').forEach(a => a.classList.remove('highlighted'));
        document.querySelectorAll('.margin-note.touch-active').forEach(n => n.classList.remove('touch-active'));
      }
    });
  }

  // INITIALIZATION
  document.addEventListener('DOMContentLoaded', () => {
    initDesktopHover();
    initTap();
  });

  window.addEventListener('load', positionMarginNotes);
  window.addEventListener('resize', () => {
    requestAnimationFrame(positionMarginNotes);
  });

  if (document.fonts) {
    document.fonts.ready.then(positionMarginNotes);
  }

  // Reposition when Deep Reading mode changes
  document.addEventListener('focusReadingChanged', () => {
    requestAnimationFrame(() => {
      setTimeout(positionMarginNotes, 350);
    });
  });
</script>
