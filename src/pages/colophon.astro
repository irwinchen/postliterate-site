---
import Base from '../layouts/Base.astro';
---

<Base title="Colophon" description="How this site is made">
  <div class="page-container">
    <main class="main-column">
      <header class="article-header">
        <h1 class="article-title">Colophon</h1>
      </header>

      <div class="article-content">
<p>
  Post-Literate is built with <a href="https://astro.build">Astro</a> and deployed on <a href="https://vercel.com">Vercel</a>. Posts are written in <a href="https://obsidian.md">Obsidian</a> as Markdown files.
</p>
<p>
  The typefaces are <a href="https://fonts.google.com/specimen/Outfit">Outfit</a> for headings and interface elements, <a href="https://fonts.google.com/specimen/Literata">Literata</a> for body text, and <a href="https://fonts.google.com/specimen/Sono">Sono</a> for code. 
</p>
<p>
  This site was built with substantial help from <a href="https://claude.ai">Claude Code</a> using Opus 4.6.
</p>
      </div>
    </main>
  </div>
</Base>
