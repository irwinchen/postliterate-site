---
import corpusData from '../../../public/corpus-treemap/structure.json';
---

<div class="ct-wrap" data-component="corpus-treemap">
  <div class="ct-header">
    <div class="ct-title-row">
      <h1 class="ct-title">What does an AI model actually train on?</h1>
      <span class="ct-caveat">Illustrative composite — no single model uses exactly this mix</span>
    </div>
    <nav class="ct-breadcrumb" aria-label="Treemap navigation" hidden>
      <button class="ct-back" aria-label="Back to all categories">← All categories</button>
      <span class="ct-breadcrumb-label"></span>
    </nav>
  </div>

  <div class="ct-body">
    <div class="ct-map-container" role="group" aria-label="Pre-training corpus treemap">
      <svg class="ct-svg" aria-hidden="true"></svg>
    </div>

    <aside class="ct-panel" aria-label="Category details" hidden>
      <div class="ct-panel-inner">
        <div class="ct-panel-swatch"></div>
        <h2 class="ct-panel-title"></h2>
        <p class="ct-panel-pct"></p>
        <p class="ct-panel-desc"></p>
        <ul class="ct-panel-bullets"></ul>
        <div class="ct-panel-screenshot-wrap" hidden>
          <img class="ct-panel-screenshot" src="" alt="" loading="lazy" />
          <p class="ct-panel-screenshot-caption"></p>
        </div>
        <div class="ct-panel-children" hidden>
          <h3 class="ct-panel-children-heading">What's in here</h3>
          <div class="ct-panel-child-cards"></div>
        </div>
        <div class="ct-panel-unknown" hidden>
          <div class="ct-redacted-block">
            <span class="ct-redacted-line">████████████████████████████</span>
            <span class="ct-redacted-line">██████████████ ████████</span>
            <span class="ct-redacted-line">████ ███████████████████████████</span>
            <p class="ct-redacted-note">Transparency score: 40/100 (FMTI 2025 average)</p>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <div class="ct-sources">
    <span class="ct-sources-label">Sources:</span>
    <span>The Pile (EleutherAI) [SECONDARY-ONLY]</span> ·
    <span>Dolma v1.7 (AI2) [SECONDARY-ONLY]</span> ·
    <span>Llama 3.1 Tech Report (Meta) [PRIMARY-PARTIAL]</span> ·
    <span>FMTI 2025 (Stanford HAI) [SECONDARY-ONLY]</span>
  </div>
</div>

<script type="module" define:vars={{ corpus: corpusData }}>
  import { squarify, contrastText } from '/src/lib/corpus-treemap/layout.js';

  const root = document.querySelector('[data-component="corpus-treemap"]');
  const svg = root.querySelector('.ct-svg');
  const panel = root.querySelector('.ct-panel');
  const panelSwatch = root.querySelector('.ct-panel-swatch');
  const panelTitle = root.querySelector('.ct-panel-title');
  const panelPct = root.querySelector('.ct-panel-pct');
  const panelDesc = root.querySelector('.ct-panel-desc');
  const panelBullets = root.querySelector('.ct-panel-bullets');
  const panelScreenshotWrap = root.querySelector('.ct-panel-screenshot-wrap');
  const panelScreenshot = root.querySelector('.ct-panel-screenshot');
  const panelScreenshotCaption = root.querySelector('.ct-panel-screenshot-caption');
  const panelChildren = root.querySelector('.ct-panel-children');
  const panelChildCards = root.querySelector('.ct-panel-child-cards');
  const panelUnknown = root.querySelector('.ct-panel-unknown');
  const breadcrumb = root.querySelector('.ct-breadcrumb');
  const breadcrumbLabel = root.querySelector('.ct-breadcrumb-label');
  const backBtn = root.querySelector('.ct-back');
  const mapContainer = root.querySelector('.ct-map-container');
  const body = root.querySelector('.ct-body');

  // State
  let currentParent = null; // null = root view; node = drill-down view
  let selectedChild = null;
  let svgW = 0, svgH = 0;

  const TOTAL = corpus.children.reduce((s, n) => s + n.value, 0);

  function pct(value) {
    return (value / TOTAL * 100).toFixed(1) + '%';
  }

  function openPanel() {
    panel.hidden = false;
    body.classList.add('ct-has-panel');
  }

  function closePanel() {
    panel.hidden = true;
    body.classList.remove('ct-has-panel');
  }

  // Thumbnails are 300px-wide crops; full screenshots are 1200px.
  function thumbPath(screenshotPath) {
    if (!screenshotPath) return null;
    return screenshotPath.replace('/corpus-treemap/screenshots/', '/corpus-treemap/thumbs/');
  }

  // ---------- Rendering ----------

  function renderRoot() {
    currentParent = null;
    selectedChild = null;
    breadcrumb.hidden = true;
    renderTiles(corpus.children, null);
    closePanel();
  }

  function renderDrillDown(parent) {
    currentParent = parent;
    selectedChild = null;
    breadcrumb.hidden = false;
    breadcrumbLabel.textContent = parent.label;

    const children = parent.children || [parent];
    renderTiles(children, parent);
    showParentPanel(parent);
  }

  function renderTiles(nodes, parent) {
    const W = svgW, H = svgH;
    if (W === 0 || H === 0) return;

    const rects = squarify(nodes, { x: 0, y: 0, w: W, h: H }, 2);

    // Clear existing tiles
    while (svg.firstChild) svg.removeChild(svg.firstChild);

    for (const r of rects) {
      const color = r.color || (parent && parent.color) || '#888';
      const textCol = r.textColor || contrastText(color);
      const isUnknown = !!r.isUnknown;

      const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      g.setAttribute('class', 'ct-tile' + (isUnknown ? ' ct-tile--unknown' : ''));
      g.setAttribute('tabindex', '0');
      g.setAttribute('role', 'button');
      g.setAttribute('aria-label', r.label + ' — ' + pct(r.value) + ' of corpus');

      // Background rect
      const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
      rect.setAttribute('x', r.x);
      rect.setAttribute('y', r.y);
      rect.setAttribute('width', r.w);
      rect.setAttribute('height', r.h);
      rect.setAttribute('fill', color);
      rect.setAttribute('class', 'ct-tile-bg');
      g.appendChild(rect);

      // Hover overlay
      const hoverRect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
      hoverRect.setAttribute('x', r.x);
      hoverRect.setAttribute('y', r.y);
      hoverRect.setAttribute('width', r.w);
      hoverRect.setAttribute('height', r.h);
      hoverRect.setAttribute('fill', 'white');
      hoverRect.setAttribute('opacity', '0');
      hoverRect.setAttribute('class', 'ct-tile-hover');
      g.appendChild(hoverRect);

      // Label (only if tile is large enough)
      const minW = 55, minH = 28;
      if (r.w >= minW && r.h >= minH) {
        const foreignNS = 'http://www.w3.org/2000/svg';
        const fo = document.createElementNS(foreignNS, 'foreignObject');
        fo.setAttribute('x', r.x + 8);
        fo.setAttribute('y', r.y + 6);
        fo.setAttribute('width', Math.max(0, r.w - 16));
        fo.setAttribute('height', Math.max(0, r.h - 12));
        fo.setAttribute('class', 'ct-tile-fo');

        const div = document.createElementNS('http://www.w3.org/1999/xhtml', 'div');
        div.className = 'ct-tile-label';
        div.style.color = textCol;

        const nameSpan = document.createElementNS('http://www.w3.org/1999/xhtml', 'span');
        nameSpan.className = 'ct-tile-name';
        if (isUnknown) {
          nameSpan.textContent = '?';
          nameSpan.style.fontSize = Math.min(r.h * 0.35, 32) + 'px';
          nameSpan.style.opacity = '0.4';
        } else {
          nameSpan.textContent = r.label;
        }
        div.appendChild(nameSpan);

        if (r.w >= 75 && r.h >= 40 && !isUnknown) {
          const pctSpan = document.createElementNS('http://www.w3.org/1999/xhtml', 'span');
          pctSpan.className = 'ct-tile-pct';
          pctSpan.textContent = pct(r.value);
          pctSpan.style.color = textCol;
          pctSpan.style.opacity = '0.75';
          div.appendChild(pctSpan);
        }

        fo.appendChild(div);
        g.appendChild(fo);
      }

      // Click handler
      g.addEventListener('click', () => handleTileClick(r, parent));
      g.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          handleTileClick(r, parent);
        }
      });

      svg.appendChild(g);
    }
  }

  function handleTileClick(node, parent) {
    if (parent === null) {
      // Root view: clicking a parent → drill down
      if (node.children && node.children.length > 0) {
        renderDrillDown(node);
      } else {
        showParentPanel(node);
      }
    } else {
      // Drill-down view: clicking a child → show child panel
      selectedChild = node;
      showChildPanel(node, parent);
    }
  }

  // ---------- Panel ----------

  function showParentPanel(node) {
    openPanel();
    panelSwatch.style.background = node.color || '#888';
    panelTitle.textContent = node.label;
    panelPct.textContent = pct(node.value) + ' of pre-training tokens';
    panelDesc.textContent = node.description || '';

    panelBullets.innerHTML = '';
    (node.bullets || []).forEach(b => {
      const li = document.createElement('li');
      li.textContent = b;
      panelBullets.appendChild(li);
    });

    panelScreenshotWrap.hidden = true;
    panelUnknown.hidden = !node.isUnknown;

    // Show child cards if node has children
    if (node.children && node.children.length > 0 && !node.isUnknown) {
      panelChildren.hidden = false;
      panelChildCards.innerHTML = '';
      for (const child of node.children) {
        const card = buildChildCard(child, node);
        panelChildCards.appendChild(card);
      }
    } else {
      panelChildren.hidden = true;
    }
  }

  function showChildPanel(child, parent) {
    openPanel();
    panelSwatch.style.background = parent.color || '#888';
    panelTitle.textContent = child.label;
    panelPct.textContent = pct(child.value) + ' of pre-training tokens';
    panelDesc.textContent = child.description || '';

    panelBullets.innerHTML = '';
    (child.bullets || []).forEach(b => {
      const li = document.createElement('li');
      if (child.isUnknown) {
        li.style.fontFamily = 'monospace';
        li.style.opacity = '0.5';
      }
      li.textContent = b;
      panelBullets.appendChild(li);
    });

    if (child.screenshot) {
      panelScreenshotWrap.hidden = false;
      panelScreenshot.src = child.screenshot;
      panelScreenshot.alt = child.screenshotCaption || child.label;
      panelScreenshotCaption.textContent = child.screenshotCaption || '';
    } else {
      panelScreenshotWrap.hidden = true;
    }

    panelChildren.hidden = true;
    panelUnknown.hidden = !child.isUnknown;
  }

  function buildChildCard(child, parent) {
    const card = document.createElement('button');
    card.className = 'ct-child-card';
    card.setAttribute('type', 'button');

    const top = document.createElement('div');
    top.className = 'ct-child-card-top';

    const thumb = thumbPath(child.screenshot);
    if (thumb) {
      const img = document.createElement('img');
      img.src = thumb;
      img.alt = '';
      img.className = 'ct-child-card-img';
      img.loading = 'lazy';
      top.appendChild(img);
    } else {
      const placeholder = document.createElement('div');
      placeholder.className = 'ct-child-card-placeholder';
      placeholder.style.background = parent.color + '33';
      top.appendChild(placeholder);
    }

    const label = document.createElement('div');
    label.className = 'ct-child-card-label';

    const name = document.createElement('strong');
    name.textContent = child.label;
    label.appendChild(name);

    const p = document.createElement('p');
    p.textContent = pct(child.value) + ' of corpus';
    label.appendChild(p);

    card.appendChild(top);
    card.appendChild(label);

    card.addEventListener('click', () => showChildPanel(child, parent));
    return card;
  }

  // ---------- Resize ----------

  function onResize() {
    const rect = mapContainer.getBoundingClientRect();
    svgW = rect.width;
    svgH = rect.height;
    svg.setAttribute('viewBox', `0 0 ${svgW} ${svgH}`);
    svg.setAttribute('width', svgW);
    svg.setAttribute('height', svgH);
    if (currentParent) {
      renderDrillDown(currentParent);
    } else {
      renderRoot();
    }
  }

  const ro = new ResizeObserver(onResize);
  ro.observe(mapContainer);

  // Back button
  backBtn.addEventListener('click', () => {
    renderRoot();
  });

  // Initial render (size may be 0 until ResizeObserver fires, but that's fine)
  onResize();
</script>

<style is:global>
  .ct-wrap {
    display: flex;
    flex-direction: column;
    height: 100%;
    font-family: 'Outfit', system-ui, sans-serif;
    color: var(--text, #2C2C2C);
    background: var(--background, #F3EFE1);
  }

  /* Header */
  .ct-header {
    padding: 16px 20px 12px;
    border-bottom: 1px solid var(--border-subtle, rgba(0,0,0,0.1));
    flex-shrink: 0;
  }

  .ct-title-row {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
  }

  .ct-title {
    font-size: clamp(16px, 1.4vw, 22px);
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .ct-caveat {
    font-size: 12px;
    color: var(--text-tertiary, #999);
    font-style: italic;
    flex-shrink: 0;
  }

  .ct-breadcrumb {
    margin-top: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ct-back {
    background: none;
    border: 1px solid var(--border-subtle, rgba(0,0,0,0.15));
    padding: 3px 10px;
    font-size: 12px;
    font-family: 'Outfit', sans-serif;
    color: var(--text-secondary, #666);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .ct-back:hover {
    background: var(--bg-highlight, rgba(229,62,51,0.05));
    color: var(--accent, #E53E33);
    border-color: var(--accent, #E53E33);
  }

  .ct-breadcrumb-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--text, #2C2C2C);
  }

  /* Main body */
  .ct-body {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr;
    min-height: 0;
    overflow: hidden;
    transition: grid-template-columns 0.2s ease;
  }

  .ct-body.ct-has-panel {
    grid-template-columns: 1fr 340px;
  }

  @media (max-width: 700px) {
    .ct-body,
    .ct-body.ct-has-panel {
      grid-template-columns: 1fr;
      grid-template-rows: 50vh 1fr;
    }
  }

  /* Treemap */
  .ct-map-container {
    position: relative;
    overflow: hidden;
  }

  .ct-svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Tile styles (SVG elements) */
  :global(.ct-tile) {
    cursor: pointer;
  }
  :global(.ct-tile:focus-visible .ct-tile-bg) {
    stroke: white;
    stroke-width: 2;
  }
  :global(.ct-tile:hover .ct-tile-hover),
  :global(.ct-tile:focus-visible .ct-tile-hover) {
    opacity: 0.12 !important;
  }
  :global(.ct-tile--unknown) {
    cursor: help;
  }
  :global(.ct-tile-fo) {
    pointer-events: none;
    overflow: hidden;
  }

  /* ForeignObject label div */
  :global(.ct-tile-label) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
  }
  :global(.ct-tile-name) {
    font-family: 'Outfit', system-ui, sans-serif;
    font-size: clamp(10px, 1.1vw, 14px);
    font-weight: 500;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
  }
  :global(.ct-tile-pct) {
    font-family: 'Outfit', system-ui, sans-serif;
    font-size: clamp(9px, 0.85vw, 11px);
    font-weight: 400;
    display: block;
  }

  /* Panel */
  .ct-panel {
    border-left: 1px solid var(--border-subtle, rgba(0,0,0,0.1));
    overflow-y: auto;
    background: var(--background, #F3EFE1);
  }

  .ct-panel-inner {
    padding: 20px;
  }

  .ct-panel-swatch {
    width: 32px;
    height: 6px;
    margin-bottom: 12px;
  }

  .ct-panel-title {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 4px;
    letter-spacing: -0.01em;
  }

  .ct-panel-pct {
    font-size: 12px;
    color: var(--text-tertiary, #999);
    margin: 0 0 12px;
  }

  .ct-panel-desc {
    font-family: 'Alegreya', 'Georgia', serif;
    font-size: 14px;
    line-height: 1.65;
    margin: 0 0 14px;
    color: var(--text, #2C2C2C);
  }

  .ct-panel-bullets {
    padding-left: 18px;
    margin: 0 0 16px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-secondary, #666);
  }
  .ct-panel-bullets li {
    margin-bottom: 6px;
  }

  /* Screenshot */
  .ct-panel-screenshot-wrap {
    margin-bottom: 16px;
  }
  .ct-panel-screenshot {
    width: 100%;
    max-height: 190px;
    object-fit: cover;
    object-position: top left;
    display: block;
    border: 1px solid var(--border-subtle, rgba(0,0,0,0.1));
  }
  .ct-panel-screenshot:hover {
    max-height: none;
    cursor: zoom-in;
  }
  .ct-panel-screenshot-caption {
    font-size: 11px;
    color: var(--text-tertiary, #999);
    margin: 5px 0 0;
    font-style: italic;
    line-height: 1.4;
  }

  /* Child cards */
  .ct-panel-children-heading {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary, #999);
    margin: 0 0 10px;
  }

  .ct-panel-child-cards {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ct-child-card {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--bg-subtle, rgba(0,0,0,0.02));
    border: 1px solid var(--border-subtle, rgba(0,0,0,0.1));
    padding: 8px;
    cursor: pointer;
    text-align: left;
    font-family: 'Outfit', sans-serif;
    transition: background 0.15s, border-color 0.15s;
    width: 100%;
  }
  .ct-child-card:hover {
    background: var(--bg-highlight, rgba(229,62,51,0.05));
    border-color: var(--accent, #E53E33);
  }

  .ct-child-card-top {
    width: 80px;
    height: 52px;
    flex-shrink: 0;
    overflow: hidden;
    position: relative;
  }
  .ct-child-card-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 80px;
    height: 52px;
    object-fit: cover;
    object-position: top left;
    display: block;
  }
  .ct-child-card-placeholder {
    width: 100%;
    height: 100%;
  }

  .ct-child-card-label strong {
    font-size: 13px;
    font-weight: 500;
    display: block;
    line-height: 1.3;
    color: var(--text, #2C2C2C);
  }
  .ct-child-card-label p {
    font-size: 11px;
    color: var(--text-tertiary, #999);
    margin: 2px 0 0;
  }

  /* Unknown / redacted */
  .ct-redacted-block {
    background: #111;
    padding: 16px;
    color: #444;
    font-family: monospace;
  }
  .ct-redacted-line {
    display: block;
    font-size: 13px;
    letter-spacing: 0.05em;
    line-height: 1.8;
    color: #333;
  }
  .ct-redacted-note {
    margin: 12px 0 0;
    font-size: 11px;
    color: #666;
    font-style: italic;
  }

  /* Sources footer */
  .ct-sources {
    padding: 8px 20px;
    font-size: 10px;
    color: var(--text-tertiary, #999);
    border-top: 1px solid var(--border-subtle, rgba(0,0,0,0.08));
    flex-shrink: 0;
    line-height: 1.5;
  }
  .ct-sources-label {
    font-weight: 600;
    margin-right: 4px;
  }
</style>
