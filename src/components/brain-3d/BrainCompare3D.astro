---
import parcelsRaw from './data/registry/parcels.json';
import papersRaw from './data/registry/papers.json';
import BrainHeader from './BrainHeader.astro';
import '../../styles/brain-3d.css';

const { viewConfigs, presets, initialActive, title } = Astro.props;
if (!Array.isArray(viewConfigs) || viewConfigs.length === 0) {
  throw new Error('BrainCompare3D: viewConfigs prop must be a non-empty array');
}
---

<div class="brain-3d brain-3d--compare" data-component="brain-compare-3d">
  <BrainHeader title={title} />

  <aside class="brain-3d__glossary" aria-label="Region glossary">
    <div class="brain-3d__glossary-list" data-bind="glossary"></div>
  </aside>

  <div class="brain-3d__center">
    <canvas class="brain-3d__canvas" aria-label="3D brain visualization"></canvas>
  </div>

  <aside class="brain-3d__rightcol brain-3d__rightcol--compare">
    <nav class="brain-3d__chip-groups" data-bind="chip-groups" aria-label="Network selector"></nav>
    <section class="brain-3d__presets" data-bind="presets" aria-label="Contrast pair presets"></section>
  </aside>

  <svg class="brain-3d__leaders" data-bind="leaders" aria-hidden="true"></svg>
</div>

<script type="module" define:vars={{
  rawParcels: parcelsRaw,
  rawPapers: papersRaw,
  viewConfigs,
  presets: presets ?? { presets: [] },
  initialActive: initialActive ?? [],
}}>
  import { loadParcelRegistry } from '/src/lib/brain-viz/parcel-registry.js';
  import { loadCompare } from '/src/lib/brain-viz/compare-loader.js';
  import { createCrossPaperState } from '/src/lib/brain-viz/cross-paper-state.js';
  import { createGlossaryState } from '/src/lib/brain-viz/glossary-state.js';
  import { createBrainRenderer } from '/src/components/brain-3d/renderer.js';

  const GROUP_NAMES = {
    'frontal':              'Frontal',
    'frontal-medial':       'Frontal-medial',
    'sensorimotor':         'Sensorimotor',
    'parietal':             'Parietal',
    'parietal-medial':      'Parietal-medial',
    'temporal':             'Temporal',
    'temporal-ventral':     'Temporal-ventral',
    'cingulate-posterior':  'Cingulate-posterior',
    'occipital':            'Occipital',
    'insula':               'Insula',
    'other':                'Other',
  };
  const GROUP_ORDER = [
    'frontal', 'frontal-medial', 'sensorimotor',
    'parietal', 'parietal-medial',
    'temporal', 'temporal-ventral', 'cingulate-posterior',
    'occipital', 'insula', 'other',
  ];

  const root = document.querySelector('[data-component="brain-compare-3d"]');
  const canvas = root.querySelector('.brain-3d__canvas');
  const leadersSvg = root.querySelector('[data-bind="leaders"]');

  const registry = loadParcelRegistry(rawParcels);
  const compare = loadCompare({ viewConfigs, registry, papersRaw: rawPapers });

  // Translate any UI-friendly preset shape ({view, network}) into the state's
  // internal (viewSlug, networkId) tuples; drop entries that don't resolve.
  function normalizePresetActive(active) {
    const out = [];
    for (const item of active ?? []) {
      const viewSlug = item.viewSlug ?? item.view;
      const networkId = item.networkId ?? item.network;
      if (!viewSlug || !networkId) continue;
      const compositeId = `${viewSlug}:${networkId}`;
      if (!compare.networks[compositeId]) continue; // skip unresolved
      out.push({ viewSlug, networkId });
    }
    return out;
  }

  const crossState = createCrossPaperState({
    initialActive: normalizePresetActive(initialActive),
  });
  const glossaryState = createGlossaryState();

  // Expose every active network's color as --mode-<compositeId> for any future
  // CSS hooks; chip elements set --chip-color directly so this is belt-and-braces.
  for (const [id, net] of Object.entries(compare.networks)) {
    root.style.setProperty(`--mode-${id}`, net.color);
  }

  // === Presets row ===
  const presetsRoot = root.querySelector('[data-bind="presets"]');
  if (presets.presets && presets.presets.length > 0) {
    const presetsLabel = document.createElement('div');
    presetsLabel.className = 'brain-3d__presets-label';
    presetsLabel.textContent = 'Contrast pairs';
    presetsRoot.appendChild(presetsLabel);

    for (const preset of presets.presets) {
      const resolved = normalizePresetActive(preset.active);
      if (resolved.length === 0) continue; // depends on views not loaded
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'brain-3d__preset';
      btn.dataset.presetId = preset.id;
      btn.textContent = preset.label;
      if (preset.subtitle) btn.title = preset.subtitle;
      btn.addEventListener('click', () => {
        crossState.setAll(resolved);
        glossaryState.clear();
      });
      presetsRoot.appendChild(btn);
    }
  } else {
    presetsRoot.style.display = 'none';
  }

  // === Chip groups (one section per view) ===
  const groupsRoot = root.querySelector('[data-bind="chip-groups"]');
  for (const viewSlug of compare.viewOrder) {
    const viewMeta = compare.views[viewSlug];

    const group = document.createElement('section');
    group.className = 'brain-3d__chip-group';
    group.dataset.viewSlug = viewSlug;

    const header = document.createElement('a');
    header.className = 'brain-3d__chip-group-label';
    header.href = `/brain/${viewSlug}`;
    header.textContent = viewMeta.name;
    header.title = `Open ${viewMeta.name} on its own page`;
    group.appendChild(header);

    const row = document.createElement('div');
    row.className = 'brain-3d__chips brain-3d__chips--compare';

    for (const compositeId of viewMeta.networkOrder) {
      const net = compare.networks[compositeId];
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'brain-3d__chip';
      btn.dataset.compositeId = compositeId;
      btn.dataset.viewSlug = net.viewSlug;
      btn.dataset.networkId = net.originalId;
      btn.innerHTML = `<span class="brain-3d__chip-num">${net.displayNum ?? ''}</span> ${net.label}`;
      btn.style.setProperty('--chip-color', net.color);
      row.appendChild(btn);
    }
    group.appendChild(row);
    groupsRoot.appendChild(group);
  }

  const clearBtn = document.createElement('button');
  clearBtn.type = 'button';
  clearBtn.className = 'brain-3d__chip brain-3d__chip--aux brain-3d__chip--clear';
  clearBtn.textContent = 'Clear all';
  clearBtn.addEventListener('click', () => {
    crossState.clear();
    glossaryState.clear();
  });
  groupsRoot.appendChild(clearBtn);

  // === Glossary panel (same structure as BrainViz3D) ===
  const allParcels = registry.parcels();
  const grouped = {};
  for (const parcel of Object.values(allParcels)) {
    const g = parcel.group ?? 'other';
    (grouped[g] ??= []).push(parcel);
  }
  for (const list of Object.values(grouped)) {
    list.sort((a, b) => a.label.localeCompare(b.label));
  }

  const glossaryRoot = root.querySelector('[data-bind="glossary"]');
  const glossaryEntryEls = new Map();

  for (const groupId of GROUP_ORDER) {
    const list = grouped[groupId];
    if (!list || list.length === 0) continue;
    const groupName = GROUP_NAMES[groupId] ?? groupId;

    const details = document.createElement('details');
    details.className = 'brain-3d__gloss-group';
    details.open = true;

    const summary = document.createElement('summary');
    summary.className = 'brain-3d__gloss-group-name';
    summary.innerHTML = `<span>${groupName.toUpperCase()}</span>`;
    details.appendChild(summary);

    const entriesWrap = document.createElement('div');
    entriesWrap.className = 'brain-3d__gloss-entries';
    for (const parcel of list) {
      const inThisView = !!compare.parcels[parcel.id];
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'brain-3d__gloss-entry';
      btn.dataset.parcelId = parcel.id;
      if (!inThisView) btn.classList.add('is-faded');
      btn.textContent = parcel.label;
      if (parcel.layCue) btn.title = parcel.layCue;
      btn.addEventListener('click', () => glossaryState.inspect(parcel.id));
      entriesWrap.appendChild(btn);
      glossaryEntryEls.set(parcel.id, btn);
    }
    details.appendChild(entriesWrap);
    glossaryRoot.appendChild(details);
  }

  function syncGlossary() {
    const inspected = glossaryState.inspectedParcels();
    for (const [id, btn] of glossaryEntryEls) {
      btn.classList.toggle('is-inspected', inspected.has(id));
    }
  }

  // === Chip wiring (cross-paper toggle semantics — no Sequential mode here) ===
  for (const chip of root.querySelectorAll('.brain-3d__chip[data-composite-id]')) {
    chip.addEventListener('click', () => {
      crossState.toggle(chip.dataset.viewSlug, chip.dataset.networkId);
    });
  }

  function syncChips() {
    const active = new Set(crossState.activeNetworks());
    for (const chip of root.querySelectorAll('.brain-3d__chip[data-composite-id]')) {
      const isActive = active.has(chip.dataset.compositeId);
      chip.classList.toggle('is-active', isActive);
      chip.setAttribute('aria-pressed', String(isActive));
    }
  }

  crossState.subscribe(() => syncChips());
  glossaryState.subscribe(() => syncGlossary());

  syncChips();
  syncGlossary();

  // === Renderer + leader-line overlay ===
  let renderer;
  if (window.WebGLRenderingContext) {
    // Renderer is view-shape-compatible: compare exposes parcels, networkColors,
    // activeNetworks (via crossState) in the same form loadView() produces.
    renderer = createBrainRenderer({ canvas, view: compare, viewState: crossState });
    renderer.onAfterRender(drawLeaderLines);
  } else {
    canvas.replaceWith(Object.assign(document.createElement('p'), {
      className: 'brain-3d__nowebgl',
      textContent: 'Your browser does not support WebGL. The 2D version of this figure is available below.',
    }));
  }

  function isEntryVisible(el) {
    return el.offsetParent !== null;
  }

  const SVG_NS = 'http://www.w3.org/2000/svg';

  function drawLeaderLines() {
    if (!renderer) return;
    while (leadersSvg.firstChild) leadersSvg.removeChild(leadersSvg.firstChild);

    const rootRect = root.getBoundingClientRect();
    const canvasRect = renderer.getCanvasRect();
    const w = rootRect.width;
    const h = rootRect.height;
    leadersSvg.setAttribute('viewBox', `0 0 ${w} ${h}`);
    leadersSvg.setAttribute('width', w);
    leadersSvg.setAttribute('height', h);

    // Direction labels — anatomical axes that follow the camera rotation.
    for (const d of renderer.getDirectionScreenPositions()) {
      if (!d.onScreen) continue;
      const t = document.createElementNS(SVG_NS, 'text');
      t.setAttribute('x', canvasRect.left + d.x - rootRect.left);
      t.setAttribute('y', canvasRect.top + d.y - rootRect.top);
      t.setAttribute('class', 'brain-3d__direction');
      t.setAttribute('text-anchor', 'middle');
      t.setAttribute('dominant-baseline', 'middle');
      t.setAttribute('opacity', '0.5');
      t.textContent = d.label;
      leadersSvg.appendChild(t);
    }

    const inspected = glossaryState.inspectedParcels();
    if (inspected.size === 0) return;

    for (const id of inspected) {
      if (!compare.parcels[id]) continue;
      const btn = glossaryEntryEls.get(id);
      if (!btn || !isEntryVisible(btn)) continue;
      const screen = renderer.getParcelScreenPosition(id);
      if (!screen || !screen.onScreen) continue;

      const entryRect = btn.getBoundingClientRect();
      const sourceX = entryRect.right - rootRect.left;
      const sourceY = entryRect.top + entryRect.height / 2 - rootRect.top;
      const targetX = canvasRect.left + screen.x - rootRect.left;
      const targetY = canvasRect.top + screen.y - rootRect.top;

      const line = document.createElementNS(SVG_NS, 'line');
      line.setAttribute('x1', sourceX);
      line.setAttribute('y1', sourceY);
      line.setAttribute('x2', targetX);
      line.setAttribute('y2', targetY);
      line.setAttribute('class', 'brain-3d__leader');
      leadersSvg.appendChild(line);

      const dot = document.createElementNS(SVG_NS, 'circle');
      dot.setAttribute('cx', targetX);
      dot.setAttribute('cy', targetY);
      dot.setAttribute('r', 4);
      dot.setAttribute('class', 'brain-3d__leader-dot');
      leadersSvg.appendChild(dot);
    }
  }
</script>

<style is:global>
  /* The base .brain-3d styles live in BrainViz3D.astro and are declared global
     there. This block only adds compare-specific selectors. */

  .brain-3d--compare {
    grid-template-rows: auto 1fr;
    grid-template-areas:
      "header header header"
      "glossary center rightcol";
  }

  /* Right column on /brain/compare hosts presets above the chip grid. Make it
     a bit wider than the single-view shell since we need room for paper labels. */
  .brain-3d__rightcol--compare {
    grid-area: rightcol;
    padding: 1.25rem 1.25rem 1.25rem 0.75rem;
    display: grid;
    align-content: start;
    gap: 1rem;
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-gutter: stable;
  }

  .brain-3d__presets {
    display: grid;
    gap: 0.4rem;
  }
  .brain-3d__presets-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--fg, #ece7d6);
    padding-block-end: 0.25rem;
  }
  .brain-3d__preset {
    appearance: none;
    background: transparent;
    border: 1px solid var(--border, rgba(255, 255, 255, 0.10));
    color: var(--fg, #ece7d6);
    font: inherit;
    font-size: 0.7rem;
    text-align: start;
    padding: 0.45rem 0.6rem;
    border-radius: 3px;
    cursor: pointer;
    transition: background-color 150ms, border-color 150ms;
  }
  .brain-3d__preset:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.20);
  }
  .brain-3d__preset:focus-visible {
    outline: 2px solid var(--fg, #ece7d6);
    outline-offset: 2px;
  }

  .brain-3d__chip-groups {
    display: grid;
    gap: 0.85rem;
  }
  .brain-3d__chip-group {
    display: grid;
    gap: 0.4rem;
  }
  .brain-3d__chip-group-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--fg, #ece7d6);
    text-decoration: none;
    transition: opacity 150ms;
  }
  .brain-3d__chip-group-label:hover {
    opacity: 0.75;
  }
  .brain-3d__chip-group-label:focus-visible {
    outline: 2px solid var(--fg, #ece7d6);
    outline-offset: 2px;
  }
  .brain-3d__chips--compare {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .brain-3d__chip--clear {
    justify-self: start;
    margin-block-start: 0.5rem;
  }

  /* Mobile: stack the right column under the canvas; presets and chips share
     the same vertical flow as in the single-view layout. */
  @media (max-width: 720px) {
    .brain-3d--compare {
      grid-template-rows: auto auto 1fr auto;
      grid-template-areas:
        "header"
        "rightcol"
        "center"
        "glossary";
      grid-template-columns: 1fr;
    }
  }
</style>
