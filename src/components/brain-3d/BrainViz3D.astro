---
import parcelsRaw from './data/registry/parcels.json';
import papersCurated from './data/registry/papers.json';
import papersUploaded from './data/registry/papers-uploaded.json';
import BrainHeader from './BrainHeader.astro';
import '../../styles/brain-3d.css';

const {
  viewConfig,
  contentConfig,
  title,
  paperMeta = null,
  glossaryMode = 'full',
  paperContent = null,
} = Astro.props;
if (!viewConfig) throw new Error('BrainViz3D: viewConfig prop is required');
if (!contentConfig) throw new Error('BrainViz3D: contentConfig prop is required');

// Curated papers + uploaded papers form a merged registry the view-loader can
// resolve viewConfig.papers[] against. Uploaded wins on collision; in practice
// the admin's save flow appends "-2" rather than overwriting.
const papersRaw = { ...papersCurated, ...papersUploaded };

const headerTitle = title ?? viewConfig.name ?? 'Brain — a reference map';

// A per-paper view = paperMeta supplied. In that case we replace the normal
// rightcol with a slide-out drawer containing the paper meta, the chip
// toolbar, and an accordion of body sections with inline parcel refs.
const isPaperView = paperMeta !== null;
const hasPaperContent = Boolean(
  paperContent && Array.isArray(paperContent.sections) && paperContent.sections.length > 0,
);
---

<div class="brain-3d" data-component="brain-viz-3d" data-paper-view={isPaperView ? 'true' : 'false'} data-panel-open="true">
  <BrainHeader title={headerTitle} />

  <aside class="brain-3d__glossary" aria-label="Region glossary">
    <div class="brain-3d__search" data-bind="search">
      <input
        type="text"
        class="brain-3d__search-input"
        data-bind="search-input"
        placeholder="Search areas…"
        autocomplete="off"
        autocapitalize="off"
        autocorrect="off"
        spellcheck="false"
        role="combobox"
        aria-expanded="false"
        aria-autocomplete="list"
        aria-controls="brain-3d-search-list"
        aria-label="Search brain areas"
      />
      <ul
        class="brain-3d__search-list"
        data-bind="search-list"
        id="brain-3d-search-list"
        role="listbox"
        aria-label="Matching areas"
        hidden
      ></ul>
    </div>
    <div class="brain-3d__glossary-list" data-bind="glossary"></div>
  </aside>

  <div class="brain-3d__center">
    <canvas class="brain-3d__canvas" aria-label="3D brain visualization"></canvas>
  </div>

  {isPaperView && (
    <button
      class="brain-3d__panel-toggle"
      type="button"
      data-action="panel-toggle"
      aria-label="Toggle paper panel"
      aria-expanded="true"
    >
      <span class="brain-3d__panel-toggle-icon" aria-hidden="true">›</span>
    </button>
  )}
  {isPaperView ? (
    <aside class="brain-3d__paper-panel" aria-label="Paper context">
      <header class="brain-3d__paper-panel-header">
        {paperMeta.title && <h2 class="brain-3d__paper-meta-title">{paperMeta.title}</h2>}
        {(paperMeta.authors || paperMeta.year) && (
          <p class="brain-3d__paper-byline">
            {paperMeta.authors}{paperMeta.authors && paperMeta.year ? ', ' : ''}{paperMeta.year}
          </p>
        )}
        {paperMeta.venue && <p class="brain-3d__paper-venue">{paperMeta.venue}</p>}
        {(paperMeta.doi || paperMeta.pdfUrl) && (
          <p class="brain-3d__paper-links">
            {paperMeta.doi && (
              <a href={`https://doi.org/${paperMeta.doi}`} target="_blank" rel="noopener">DOI ↗</a>
            )}
            {paperMeta.pdfUrl && (
              <a href={paperMeta.pdfUrl} target="_blank" rel="noopener">View PDF ↗</a>
            )}
          </p>
        )}
        <nav class="brain-3d__chips" role="toolbar" aria-label="Network selector" data-bind="chips"></nav>
      </header>

      <div class="brain-3d__paper-body">
        {hasPaperContent ? (
          paperContent.sections.map((section) => (
            <details class="brain-3d__paper-section" open>
              <summary class="brain-3d__paper-section-summary">
                <span class="brain-3d__paper-section-caret" aria-hidden="true">▾</span>
                <span class="brain-3d__paper-section-heading">{section.heading || 'Untitled section'}</span>
                <button
                  type="button"
                  class="brain-3d__paper-section-highlight"
                  data-action="section-highlight"
                  aria-pressed="false"
                  title="Highlight every region this section mentions"
                >Highlight all</button>
              </summary>
              {section.paragraphs.length > 0 && (
                <div class="brain-3d__paper-paragraphs">
                  {section.paragraphs.map((p) => (
                    <p class="brain-3d__paper-paragraph">
                      {p.segments.map((seg) =>
                        seg.type === 'ref' ? (
                          <button
                            class="brain-3d__paper-ref"
                            type="button"
                            data-parcel-id={seg.parcelId}
                            aria-label={`Inspect ${seg.value}`}
                          >
                            {seg.value}
                          </button>
                        ) : (
                          <Fragment>{seg.value}</Fragment>
                        ),
                      )}
                    </p>
                  ))}
                </div>
              )}
              {section.subsections && section.subsections.length > 0 && (
                <div class="brain-3d__paper-subsections">
                  {section.subsections.map((sub) => (
                    <details class="brain-3d__paper-subsection" open>
                      <summary class="brain-3d__paper-subsection-summary">
                        <span class="brain-3d__paper-section-caret" aria-hidden="true">▾</span>
                        <span class="brain-3d__paper-section-heading">{sub.heading || 'Untitled subsection'}</span>
                        <button
                          type="button"
                          class="brain-3d__paper-section-highlight"
                          data-action="section-highlight"
                          aria-pressed="false"
                          title="Highlight every region this subsection mentions"
                        >Highlight all</button>
                      </summary>
                      <div class="brain-3d__paper-paragraphs">
                        {sub.paragraphs.map((p) => (
                          <p class="brain-3d__paper-paragraph">
                            {p.segments.map((seg) =>
                              seg.type === 'ref' ? (
                                <button
                                  class="brain-3d__paper-ref"
                                  type="button"
                                  data-parcel-id={seg.parcelId}
                                  aria-label={`Inspect ${seg.value}`}
                                >
                                  {seg.value}
                                </button>
                              ) : (
                                <Fragment>{seg.value}</Fragment>
                              ),
                            )}
                          </p>
                        ))}
                      </div>
                    </details>
                  ))}
                </div>
              )}
            </details>
          ))
        ) : (
          <p class="brain-3d__paper-empty">
            Re-extract this paper from the admin Papers tab to populate inline paragraph context.
          </p>
        )}
      </div>
    </aside>
  ) : (
    <aside class="brain-3d__rightcol">
      <nav class="brain-3d__chips" role="toolbar" aria-label="Network selector" data-bind="chips"></nav>
    </aside>
  )}

  <svg class="brain-3d__leaders" data-bind="leaders" aria-hidden="true"></svg>
  <div class="brain-3d__tooltip" data-bind="tooltip" role="tooltip" aria-hidden="true"></div>
</div>

<script
  type="application/json"
  data-brain-viz-config
  is:inline
  set:html={JSON.stringify({
    rawParcels: parcelsRaw,
    rawPapers: papersRaw,
    viewConfig,
    contentConfig,
    glossaryMode,
    isPaperView,
  })}
></script>

<script>
  // Imports use relative paths so Astro/Vite bundles them for production.
  // Page data is read from the JSON blob above instead of `define:vars`,
  // because `define:vars` forces a script `is:inline`, which prevents Vite
  // from processing the imports — leaving `/src/...` paths that 404 once
  // deployed to a static host.
  import { loadParcelRegistry } from '../../lib/brain-viz/parcel-registry.js';
  import { loadView } from '../../lib/brain-viz/view-loader.js';
  import { createViewState } from '../../lib/brain-viz/view-state.js';
  import { createGlossaryState } from '../../lib/brain-viz/glossary-state.js';
  import { searchParcels } from '../../lib/brain-viz/parcel-search.js';
  import { createViewContent } from '../../lib/brain-viz/content.js';
  import { computeVisibleLabels } from '../../lib/brain-viz/label-visibility.js';
  import { pickContrastText } from '../../lib/brain-viz/emissive.js';
  import { createBrainRenderer } from './renderer.js';

  const { rawParcels, rawPapers, viewConfig, contentConfig, glossaryMode, isPaperView } = JSON.parse(
    document.querySelector('[data-brain-viz-config]').textContent
  );

  // Anatomical group display names. Subtitles are intentionally omitted in the
  // compact glossary layout; reintroduce as <details> tooltips later if needed.
  const GROUP_NAMES = {
    'frontal':              'Frontal',
    'frontal-medial':       'Frontal-medial',
    'sensorimotor':         'Sensorimotor',
    'parietal':             'Parietal',
    'parietal-medial':      'Parietal-medial',
    'temporal':             'Temporal',
    'temporal-ventral':     'Temporal-ventral',
    'cingulate-posterior':  'Cingulate-posterior',
    'occipital':            'Occipital',
    'insula':               'Insula',
    'other':                'Other',
  };
  const GROUP_ORDER = [
    'frontal', 'frontal-medial', 'sensorimotor',
    'parietal', 'parietal-medial',
    'temporal', 'temporal-ventral', 'cingulate-posterior',
    'occipital', 'insula', 'other',
  ];

  const root = document.querySelector('[data-component="brain-viz-3d"]');
  const canvas = root.querySelector('.brain-3d__canvas');
  const leadersSvg = root.querySelector('[data-bind="leaders"]');
  const tooltipEl = root.querySelector('[data-bind="tooltip"]');

  const registry = loadParcelRegistry(rawParcels);
  const view = loadView({ viewConfig, registry, papersRaw: rawPapers });
  const content = createViewContent(contentConfig);
  const viewState = createViewState({
    networkIds: view.networkOrder,
    initialNetwork: view.view.defaultNetwork,
    // Per-paper views treat chips as pure toggles — any combination is valid,
    // including zero active. Curated views keep the original "always one
    // visible" guard.
    allowZero: isPaperView,
  });
  if (isPaperView) viewState.enterCompare();
  const glossaryState = createGlossaryState();

  for (const id of view.networkOrder) {
    root.style.setProperty(`--mode-${id}`, view.networks[id].color);
  }

  // === Build the chips ===
  // For multi-network views the chip is an interactive button; for an N=1 view
  // (e.g. VWFA) the network is permanently active, so the chip becomes a static
  // label — no click target, no Compare/All controls, no vestigial UI.
  const isMulti = view.networkOrder.length > 1;
  const chipsRoot = root.querySelector('[data-bind="chips"]');
  for (const id of view.networkOrder) {
    const net = view.networks[id];
    if (isMulti) {
      const btn = document.createElement('button');
      btn.className = 'brain-3d__chip';
      btn.dataset.network = id;
      btn.innerHTML = `<span class="brain-3d__chip-num">${net.displayNum ?? ''}</span> ${net.label}`;
      btn.style.setProperty('--chip-color', net.color);
      btn.style.setProperty('--chip-text-color', pickContrastText(net.color));
      chipsRoot.appendChild(btn);
    } else {
      const label = document.createElement('div');
      label.className = 'brain-3d__chip brain-3d__chip--static is-active';
      label.innerHTML = `<span class="brain-3d__chip-num">${net.displayNum ?? ''}</span> ${net.label}`;
      label.style.setProperty('--chip-color', net.color);
      label.style.setProperty('--chip-text-color', pickContrastText(net.color));
      label.setAttribute('aria-label', `Active network: ${net.label}`);
      chipsRoot.appendChild(label);
    }
  }

  if (isMulti) {
    // Per-paper views are permanently in compare mode (chips toggle freely),
    // so the Compare button is redundant — skip it. The All button stays in
    // both contexts as a useful "light everything up" shortcut.
    if (!isPaperView) {
      const compareBtn = document.createElement('button');
      compareBtn.className = 'brain-3d__chip brain-3d__chip--aux';
      compareBtn.dataset.action = 'compare';
      compareBtn.setAttribute('aria-pressed', 'false');
      compareBtn.textContent = 'Compare';
      chipsRoot.appendChild(compareBtn);
    }

    const allBtn = document.createElement('button');
    allBtn.className = 'brain-3d__chip brain-3d__chip--aux';
    allBtn.dataset.action = 'all';
    allBtn.textContent = 'All';
    chipsRoot.appendChild(allBtn);
  }
  const resetBtn = document.createElement('button');
  resetBtn.className = 'brain-3d__chip brain-3d__chip--aux';
  resetBtn.dataset.action = 'reset';
  resetBtn.textContent = 'Reset';
  chipsRoot.appendChild(resetBtn);

  // === Glossary tooltip ===
  function showTooltipFor(parcelId, anchorEl) {
    const parcel = registry.byId(parcelId);
    if (!parcel?.note) {
      hideTooltip();
      return;
    }
    const titleEl = document.createElement('div');
    titleEl.className = 'brain-3d__tooltip-title';
    titleEl.textContent = parcel.label;
    const bodyEl = document.createElement('div');
    bodyEl.className = 'brain-3d__tooltip-body';
    bodyEl.textContent = parcel.note;
    while (tooltipEl.firstChild) tooltipEl.removeChild(tooltipEl.firstChild);
    tooltipEl.appendChild(titleEl);
    tooltipEl.appendChild(bodyEl);
    tooltipEl.style.transform = 'translate(0, 0)';
    tooltipEl.classList.add('is-visible');
    tooltipEl.setAttribute('aria-hidden', 'false');
    const aRect = anchorEl.getBoundingClientRect();
    const rRect = root.getBoundingClientRect();
    const tRect = tooltipEl.getBoundingClientRect();
    const x = aRect.right - rRect.left + 10;
    let y = aRect.top - rRect.top + (aRect.height - tRect.height) / 2;
    y = Math.max(8, Math.min(rRect.height - tRect.height - 8, y));
    tooltipEl.style.transform = `translate(${x}px, ${y}px)`;
  }
  function hideTooltip() {
    tooltipEl.classList.remove('is-visible');
    tooltipEl.setAttribute('aria-hidden', 'true');
  }

  // === Build the glossary (collapsible <details> per anatomical group) ===
  // glossaryMode 'in-view-only' is for per-paper views: the left column only
  // lists the regions THIS paper discusses, instead of the full registry
  // (faded for off-view parcels). All other ergonomics — group nesting, click
  // to inspect, hover for note — work identically.
  const glossarySource = glossaryMode === 'in-view-only' ? view.parcels : registry.parcels();
  const grouped = {};
  for (const parcel of Object.values(glossarySource)) {
    const g = parcel.group ?? 'other';
    (grouped[g] ??= []).push(parcel);
  }
  for (const list of Object.values(grouped)) {
    list.sort((a, b) => a.label.localeCompare(b.label));
  }

  const glossaryRoot = root.querySelector('[data-bind="glossary"]');
  const glossaryEntryEls = new Map(); // parcelId -> button element

  for (const groupId of GROUP_ORDER) {
    const list = grouped[groupId];
    if (!list || list.length === 0) continue;
    const groupName = GROUP_NAMES[groupId] ?? groupId;

    const details = document.createElement('details');
    details.className = 'brain-3d__gloss-group';
    details.open = false; // start collapsed so the column fits without scrolling

    const summary = document.createElement('summary');
    summary.className = 'brain-3d__gloss-group-name';
    summary.innerHTML = `<span>${groupName.toUpperCase()}</span>`;
    details.appendChild(summary);

    const entriesWrap = document.createElement('div');
    entriesWrap.className = 'brain-3d__gloss-entries';
    for (const parcel of list) {
      const inThisView = !!view.parcels[parcel.id];
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'brain-3d__gloss-entry';
      btn.dataset.parcelId = parcel.id;
      if (!inThisView) btn.classList.add('is-faded');
      btn.textContent = parcel.label;
      btn.addEventListener('click', () => glossaryState.inspect(parcel.id));
      btn.addEventListener('mouseenter', () => showTooltipFor(parcel.id, btn));
      btn.addEventListener('mouseleave', hideTooltip);
      btn.addEventListener('focus', () => showTooltipFor(parcel.id, btn));
      btn.addEventListener('blur', hideTooltip);
      entriesWrap.appendChild(btn);
      glossaryEntryEls.set(parcel.id, btn);
    }
    details.appendChild(entriesWrap);
    glossaryRoot.appendChild(details);
  }

  // === Glossary highlighting wiring ===
  function syncGlossary() {
    const inspected = glossaryState.inspectedParcels();
    for (const [id, btn] of glossaryEntryEls) {
      const on = inspected.has(id);
      btn.classList.toggle('is-inspected', on);
      // Groups start collapsed; reveal a group whenever one of its terms is
      // inspected so its leader line can draw (drawLeaderLines skips entries
      // hidden inside a closed <details>). Covers inline refs + Highlight all.
      if (on) {
        const grp = btn.closest('details');
        if (grp && !grp.open) grp.open = true;
      }
    }
  }

  // === Chip wiring ===
  // Per-paper views: chips are pure toggles (allowZero in view-state lets the
  // last one go off). Curated views: sequential by default, toggle while in
  // explicit compare mode, with the "always one active" guard preserved.
  for (const chip of root.querySelectorAll('.brain-3d__chip[data-network]')) {
    chip.addEventListener('click', () => {
      const id = chip.dataset.network;
      if (isPaperView) {
        viewState.toggle(id);
      } else if (viewState.isCompare()) {
        const active = viewState.activeNetworks();
        if (active.includes(id) && active.length === 1) return;
        viewState.toggle(id);
      } else {
        viewState.select(id);
      }
    });
  }
  function syncChips() {
    const active = viewState.activeNetworks();
    const isCompare = viewState.isCompare();
    for (const chip of root.querySelectorAll('.brain-3d__chip[data-network]')) {
      const id = chip.dataset.network;
      const isActive = active.includes(id);
      chip.classList.toggle('is-active', isActive);
      chip.setAttribute('aria-pressed', String(isActive));
    }
    const compareBtn = root.querySelector('[data-action="compare"]');
    if (compareBtn) {
      compareBtn.classList.toggle('is-active', isCompare);
      compareBtn.setAttribute('aria-pressed', String(isCompare));
    }
  }
  const compareBtn = root.querySelector('[data-action="compare"]');
  if (compareBtn) {
    compareBtn.addEventListener('click', () => {
      if (viewState.isCompare()) viewState.exitCompare();
      else viewState.enterCompare();
    });
  }
  const allBtn = root.querySelector('[data-action="all"]');
  if (allBtn) allBtn.addEventListener('click', () => viewState.showAll());
  root.querySelector('[data-action="reset"]').addEventListener('click', () => {
    viewState.reset();
    glossaryState.clear();
  });

  viewState.subscribe(() => syncChips());
  glossaryState.subscribe(() => syncGlossary());

  syncChips();
  syncGlossary();

  // === Renderer + leader-line overlay ===
  let renderer;
  if (window.WebGLRenderingContext) {
    renderer = createBrainRenderer({ canvas, view, viewState });
    renderer.onAfterRender(drawLeaderLines);
  } else {
    canvas.replaceWith(Object.assign(document.createElement('p'), {
      className: 'brain-3d__nowebgl',
      textContent: 'Your browser does not support WebGL. The 2D version of this figure is available below.',
    }));
  }

  // === Paper-panel wiring (per-paper views only) ===
  if (isPaperView) {
    // Panel-open state persists per-view so users get the same drawer
    // position they last saw on this specific paper.
    const PANEL_KEY = `brain-paper-panel-open:${viewConfig.slug}`;
    const stored = localStorage.getItem(PANEL_KEY);
    const initialOpen = stored === null ? true : stored !== 'false';
    root.setAttribute('data-panel-open', String(initialOpen));

    const toggleBtn = root.querySelector('[data-action="panel-toggle"]');
    if (toggleBtn) {
      toggleBtn.setAttribute('aria-expanded', String(initialOpen));
      toggleBtn.addEventListener('click', () => {
        const wasOpen = root.getAttribute('data-panel-open') !== 'false';
        const nextOpen = !wasOpen;
        root.setAttribute('data-panel-open', String(nextOpen));
        toggleBtn.setAttribute('aria-expanded', String(nextOpen));
        localStorage.setItem(PANEL_KEY, String(nextOpen));
        // Canvas resize is observed by the renderer via ResizeObserver; the
        // grid-template-columns transition will trigger it implicitly. Force
        // a leader redraw at the end so dots/lines stop pointing at stale
        // positions during the transition tail.
        setTimeout(() => { if (renderer) drawLeaderLines(); }, 260);
      });
    }

    // Inline ref → inspect that parcel and pulse it once. Inspect alone
    // (which the glossary uses) draws a leader line; the pulse adds the
    // "this is the parcel" visual confirmation without disturbing whichever
    // network is currently active.
    function networkColorForParcel(parcelId) {
      const parcel = view.parcels[parcelId];
      if (!parcel || !parcel.networks || parcel.networks.length === 0) return '#ffffff';
      const netId = parcel.networks[0];
      return view.networks[netId]?.color ?? '#ffffff';
    }

    // refsByParcelId: same parcel can appear in multiple paragraphs, so we
    // index every ref button by its parcelId for the inspected-class sync.
    const refsByParcelId = new Map();
    for (const refBtn of root.querySelectorAll('.brain-3d__paper-ref[data-parcel-id]')) {
      const parcelId = refBtn.dataset.parcelId;
      if (!refsByParcelId.has(parcelId)) refsByParcelId.set(parcelId, []);
      refsByParcelId.get(parcelId).push(refBtn);
      refBtn.addEventListener('click', () => {
        if (!view.parcels[parcelId]) return;
        const wasInspected = glossaryState.isInspected(parcelId);
        glossaryState.inspect(parcelId);
        // Only pulse when turning ON — pulsing on un-inspect is meaningless.
        if (!wasInspected && renderer && typeof renderer.pulseParcel === 'function') {
          renderer.pulseParcel(parcelId, {
            color: networkColorForParcel(parcelId),
            durationMs: 1200,
          });
        }
      });
    }

    // Per-section "highlight all" — collects the parcelIds referenced in
    // every paragraph inside the section's <details> (including nested
    // subsections, when the button is on a top-level section). On click:
    // if every parcel is already inspected, uninspect all; otherwise
    // inspect any that aren't yet on. Toggles aria-pressed for styling.
    function sectionParcelIds(sectionEl) {
      const refs = sectionEl.querySelectorAll('.brain-3d__paper-ref[data-parcel-id]');
      const ids = new Set();
      for (const r of refs) ids.add(r.dataset.parcelId);
      return [...ids];
    }
    function allInspected(ids) {
      return ids.length > 0 && ids.every((id) => glossaryState.isInspected(id));
    }
    for (const btn of root.querySelectorAll('[data-action="section-highlight"]')) {
      btn.addEventListener('click', (ev) => {
        // Prevent the <summary> click from collapsing the section.
        ev.preventDefault();
        ev.stopPropagation();
        const sectionEl = btn.closest('details');
        if (!sectionEl) return;
        const ids = sectionParcelIds(sectionEl);
        if (ids.length === 0) return;
        const turningOff = allInspected(ids);
        for (const id of ids) {
          const isOn = glossaryState.isInspected(id);
          if (turningOff && isOn) glossaryState.inspect(id);
          else if (!turningOff && !isOn) {
            glossaryState.inspect(id);
            // Stagger pulses very slightly so the eye can pick out each one.
            if (renderer && typeof renderer.pulseParcel === 'function') {
              renderer.pulseParcel(id, {
                color: networkColorForParcel(id),
                durationMs: 1400,
              });
            }
          }
        }
      });
    }

    // Sync the inline-ref highlighting + section-button pressed state from
    // glossary state. Same source of truth as the leader lines so the panel
    // and the brain agree on which parcels are "on" at any moment.
    function syncPaperHighlights() {
      const inspected = glossaryState.inspectedParcels();
      for (const [parcelId, refs] of refsByParcelId) {
        const on = inspected.has(parcelId);
        for (const r of refs) r.classList.toggle('is-inspected', on);
      }
      for (const btn of root.querySelectorAll('[data-action="section-highlight"]')) {
        const sectionEl = btn.closest('details');
        if (!sectionEl) continue;
        const ids = sectionParcelIds(sectionEl);
        const all = allInspected(ids);
        btn.setAttribute('aria-pressed', String(all));
      }
    }
    glossaryState.subscribe(syncPaperHighlights);
    syncPaperHighlights();
  }

  // === Lookahead area search ===
  // Type the first few characters of an area name; pick a match to graph it.
  // Only parcels in this view get a mesh (and thus a leader line / pulse), so
  // the search corpus is exactly view.parcels regardless of glossaryMode.
  const searchableParcels = Object.values(view.parcels);
  const searchInput = root.querySelector('[data-bind="search-input"]');
  const searchList = root.querySelector('[data-bind="search-list"]');
  let searchResults = [];
  let searchActiveIndex = -1;

  function searchPulseColor(parcelId) {
    const parcel = view.parcels[parcelId];
    const netId = parcel?.networks?.[0];
    return view.networks[netId]?.color ?? '#d89233';
  }

  function closeSearchList() {
    searchList.hidden = true;
    searchList.replaceChildren();
    searchInput.setAttribute('aria-expanded', 'false');
    searchInput.removeAttribute('aria-activedescendant');
    searchResults = [];
    searchActiveIndex = -1;
  }

  function renderSearchList() {
    searchList.replaceChildren();
    if (searchResults.length === 0) {
      closeSearchList();
      return;
    }
    searchResults.forEach((parcel, i) => {
      const li = document.createElement('li');
      li.className = 'brain-3d__search-option';
      li.id = `brain-3d-search-opt-${i}`;
      li.setAttribute('role', 'option');
      li.setAttribute('aria-selected', String(i === searchActiveIndex));
      li.classList.toggle('is-active', i === searchActiveIndex);
      li.textContent = parcel.label;
      // mousedown (not click) so the selection fires before the input's blur
      // tears the list down.
      li.addEventListener('mousedown', (e) => {
        e.preventDefault();
        selectSearchResult(i);
      });
      searchList.appendChild(li);
    });
    searchList.hidden = false;
    searchInput.setAttribute('aria-expanded', 'true');
    if (searchActiveIndex >= 0) {
      searchInput.setAttribute('aria-activedescendant', `brain-3d-search-opt-${searchActiveIndex}`);
    } else {
      searchInput.removeAttribute('aria-activedescendant');
    }
  }

  function moveActive(delta) {
    if (searchResults.length === 0) return;
    const n = searchResults.length;
    searchActiveIndex = (searchActiveIndex + delta + n) % n;
    renderSearchList();
    const el = searchList.children[searchActiveIndex];
    if (el) el.scrollIntoView({ block: 'nearest' });
  }

  function selectSearchResult(i) {
    const parcel = searchResults[i] ?? searchResults[searchActiveIndex] ?? searchResults[0];
    if (!parcel) return;
    searchInput.value = parcel.label;
    closeSearchList();
    graphParcel(parcel.id);
  }

  // Graph a parcel: ensure its leader line is on, pulse the mesh, and reveal +
  // flash its glossary entry so the user can see where it landed in the list.
  function graphParcel(parcelId) {
    if (!glossaryState.isInspected(parcelId)) glossaryState.inspect(parcelId);
    if (renderer && typeof renderer.pulseParcel === 'function') {
      renderer.pulseParcel(parcelId, { color: searchPulseColor(parcelId), durationMs: 1400 });
    }

    const entry = glossaryEntryEls.get(parcelId);
    if (entry) {
      const group = entry.closest('details');
      if (group) group.open = true;
      entry.scrollIntoView({ block: 'nearest' });
      entry.classList.remove('is-flash');
      // Force reflow so re-adding the class restarts the animation.
      void entry.offsetWidth;
      entry.classList.add('is-flash');
    }
  }

  searchInput.addEventListener('input', () => {
    searchResults = searchParcels(searchableParcels, searchInput.value, { limit: 8 });
    searchActiveIndex = searchResults.length ? 0 : -1;
    renderSearchList();
  });

  searchInput.addEventListener('keydown', (e) => {
    switch (e.key) {
      case 'ArrowDown':
        e.preventDefault();
        moveActive(1);
        break;
      case 'ArrowUp':
        e.preventDefault();
        moveActive(-1);
        break;
      case 'Enter':
        if (searchResults.length) {
          e.preventDefault();
          selectSearchResult(searchActiveIndex);
        }
        break;
      case 'Escape':
        if (!searchList.hidden) {
          e.preventDefault();
          closeSearchList();
        } else if (searchInput.value) {
          searchInput.value = '';
        }
        break;
    }
  });

  searchInput.addEventListener('blur', () => {
    // Defer so a mousedown on an option still registers before teardown.
    setTimeout(closeSearchList, 0);
  });

  function isEntryVisible(el) {
    // Element is rendered (not inside a collapsed <details>) iff offsetParent is non-null
    return el.offsetParent !== null;
  }

  // Where a parcel's leader line originates: its own glossary entry when that
  // entry is visible; when its group is collapsed (entry hidden) it falls back
  // to the group header, so closing a group with inspected terms retargets the
  // lines to the parent group row instead of dropping them. Null if the group
  // header is itself hidden (e.g. mobile-collapsed glossary).
  function leaderAnchorEl(btn) {
    // A closed <details> still reports offsetParent !== null for its children in
    // current Chromium, so test the [open] attribute directly rather than
    // trusting isEntryVisible here. When the term's group is collapsed, anchor
    // at its header so the line retargets the parent row instead of staying on
    // the hidden entry.
    const closedGroup = btn.closest('details:not([open])');
    const anchor = closedGroup ? closedGroup.querySelector('summary') : btn;
    return anchor && isEntryVisible(anchor) ? anchor : null;
  }

  const SVG_NS = 'http://www.w3.org/2000/svg';

  function drawLeaderLines() {
    if (!renderer) return;

    // Clear previous content unconditionally so toggling-off cleans up.
    while (leadersSvg.firstChild) leadersSvg.removeChild(leadersSvg.firstChild);

    const rootRect = root.getBoundingClientRect();
    const canvasRect = renderer.getCanvasRect();

    const w = rootRect.width;
    const h = rootRect.height;
    leadersSvg.setAttribute('viewBox', `0 0 ${w} ${h}`);
    leadersSvg.setAttribute('width', w);
    leadersSvg.setAttribute('height', h);

    for (const d of renderer.getDirectionScreenPositions()) {
      if (!d.onScreen) continue;
      const t = document.createElementNS(SVG_NS, 'text');
      t.setAttribute('x', canvasRect.left + d.x - rootRect.left);
      t.setAttribute('y', canvasRect.top + d.y - rootRect.top);
      t.setAttribute('class', 'brain-3d__direction');
      t.setAttribute('text-anchor', 'middle');
      t.setAttribute('dominant-baseline', 'middle');
      t.setAttribute('opacity', '0.5');
      t.textContent = d.label;
      leadersSvg.appendChild(t);
    }

    const inspected = glossaryState.inspectedParcels();
    if (inspected.size === 0) return;

    for (const id of inspected) {
      if (!view.parcels[id]) continue;
      const btn = glossaryEntryEls.get(id);
      if (!btn) continue;
      const anchorEl = leaderAnchorEl(btn);
      if (!anchorEl) continue;
      const screen = renderer.getParcelScreenPosition(id);
      if (!screen || !screen.onScreen) continue;

      const entryRect = anchorEl.getBoundingClientRect();
      const sourceX = entryRect.right - rootRect.left;
      const sourceY = entryRect.top + entryRect.height / 2 - rootRect.top;
      const targetX = canvasRect.left + screen.x - rootRect.left;
      const targetY = canvasRect.top + screen.y - rootRect.top;

      const line = document.createElementNS(SVG_NS, 'line');
      line.setAttribute('x1', sourceX);
      line.setAttribute('y1', sourceY);
      line.setAttribute('x2', targetX);
      line.setAttribute('y2', targetY);
      line.setAttribute('class', 'brain-3d__leader');
      leadersSvg.appendChild(line);

      const dot = document.createElementNS(SVG_NS, 'circle');
      dot.setAttribute('cx', targetX);
      dot.setAttribute('cy', targetY);
      dot.setAttribute('r', 4);
      dot.setAttribute('class', 'brain-3d__leader-dot');
      leadersSvg.appendChild(dot);
    }
  }
</script>

