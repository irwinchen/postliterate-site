---
/**
 * Figure Component
 *
 * Usage in MDX:
 * import Figure from '../../components/Figure.astro';
 * <Figure caption="Description of the image">
 *   <img src="/images/example.jpg" alt="Alt text" />
 * </Figure>
 *
 * Split layout (image left, text right):
 * <Figure layout="split" caption="Longer transcription or description text...">
 *   <img src="/images/example.jpg" alt="Alt text" />
 * </Figure>
 */

interface Props {
  caption?: string;
  layout?: 'default' | 'split';
}

let { caption, layout = 'default' } = Astro.props;
// Support "split:" prefix in caption as shorthand for layout="split"
if (caption && /^split:\s*/i.test(caption)) {
  caption = caption.replace(/^split:\s*/i, '');
  layout = 'split';
}
const isSplit = layout === 'split';
---

<figure class:list={['figure', { 'figure-split': isSplit }]} data-lightbox>
  <div class="figure-content">
    <slot />
  </div>
  {caption && <figcaption class="figure-caption">{caption}</figcaption>}
</figure>
