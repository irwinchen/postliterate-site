---
/**
 * CorpusVoronoi — brain-shaped bubble pack of AI pre-training data.
 *
 * Note on naming: the directory is still called `corpus-voronoi` for
 * historical reasons. The current algorithm is bubble packing
 * (`d3-hierarchy.pack()`), not Voronoi. See DESIGN.md for context.
 *
 * Phase 3: static render only. Loads the precomputed root layout and
 * renders the brain silhouette as a backdrop with its 11 colored bubbles
 * clustered inside. No interactivity yet — modal drill-in, panel, and
 * animations come in later phases.
 *
 * Layout JSON is generated by `npm run voronoi:build`
 * (src/lib/corpus-voronoi/layout-build.mjs).
 */
import rootLayout from '../../../public/corpus-treemap/voronoi-root.json';

const { canvas, cells } = rootLayout;
const [vx, vy, vw, vh] = canvas.viewBox;

const TOTAL = cells.reduce((s, c) => s + c.value, 0);
const pct = (v) => ((v / TOTAL) * 100).toFixed(1) + '%';

// Decide what to show inside each bubble based on size. Very small bubbles
// get only the label (no percentage); tiny bubbles get nothing.
function labelMode(r) {
  if (r >= 50) return 'full'; // label + percentage
  if (r >= 28) return 'label';
  return 'none';
}
---

<div class="cv-wrap" data-component="corpus-voronoi">
  <header class="cv-header">
    <h1 class="cv-title">What does an AI model actually train on?</h1>
    <p class="cv-caveat">
      Illustrative composite — no single model uses exactly this mix.
    </p>
  </header>

  <div class="cv-stage">
    <svg
      class="cv-svg"
      viewBox={`${vx} ${vy} ${vw} ${vh}`}
      preserveAspectRatio="xMidYMid meet"
      role="img"
      aria-label="Pre-training corpus visualized as a cluster of bubbles, each sized by its share of training tokens"
    >
      <g class="cv-bubbles">
        {cells.map((c) => {
          const mode = labelMode(c.r);
          return (
            <g
              class="cv-bubble"
              data-id={c.id}
              data-has-children={c.hasChildren ? 'true' : 'false'}
            >
              <circle
                cx={c.x}
                cy={c.y}
                r={c.r}
                fill={c.color || '#888'}
                class="cv-bubble-fill"
              />
              {mode !== 'none' && (
                <text
                  x={c.x}
                  y={mode === 'full' ? c.y - 4 : c.y}
                  text-anchor="middle"
                  dominant-baseline="middle"
                  class="cv-bubble-label"
                >
                  {c.label}
                </text>
              )}
              {mode === 'full' && (
                <text
                  x={c.x}
                  y={c.y + 16}
                  text-anchor="middle"
                  dominant-baseline="middle"
                  class="cv-bubble-pct"
                >
                  {pct(c.value)}
                </text>
              )}
            </g>
          );
        })}
      </g>
    </svg>
  </div>

  <footer class="cv-sources">
    <span class="cv-sources-label">Sources:</span>
    <span>The Pile (EleutherAI) [SECONDARY-ONLY]</span> ·
    <span>Dolma v1.7 (AI2) [SECONDARY-ONLY]</span> ·
    <span>Llama 3.1 Tech Report (Meta) [PRIMARY-PARTIAL]</span> ·
    <span>FMTI 2025 (Stanford HAI) [SECONDARY-ONLY]</span>
  </footer>
</div>

<style>
  .cv-wrap {
    display: grid;
    grid-template-rows: auto 1fr auto;
    block-size: 100%;
    padding-block: 20px;
    padding-inline: clamp(16px, 4vw, 48px);
    row-gap: 8px;
    color: var(--text);
    font-family: 'Outfit', system-ui, sans-serif;
  }

  .cv-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 16px;
  }
  .cv-title {
    font-size: clamp(20px, 2.2vw, 30px);
    font-weight: 500;
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .cv-caveat {
    font-size: 12px;
    color: var(--text-tertiary);
    font-style: italic;
    margin: 0;
  }

  .cv-stage {
    display: grid;
    place-items: center;
    min-block-size: 0;
    min-inline-size: 0;
    overflow: hidden;
  }
  .cv-svg {
    inline-size: 100%;
    block-size: 100%;
    max-inline-size: 1200px;
    display: block;
  }

  .cv-bubble-fill {
    stroke: var(--background);
    stroke-width: 2;
  }
  .cv-bubble-label {
    font-size: clamp(11px, 1.05vw, 15px);
    fill: #fff;
    pointer-events: none;
    font-weight: 500;
    font-family: 'Outfit', system-ui, sans-serif;
  }
  .cv-bubble-pct {
    font-size: clamp(9px, 0.85vw, 12px);
    fill: rgba(255, 255, 255, 0.78);
    pointer-events: none;
    font-weight: 400;
    font-family: 'Outfit', system-ui, sans-serif;
  }
  .cv-bubble {
    cursor: default; /* Phase 3: no interaction yet. */
  }

  .cv-sources {
    font-size: 11px;
    color: var(--text-tertiary);
    text-align: center;
    padding-block: 8px;
  }
  .cv-sources-label {
    font-weight: 600;
    margin-inline-end: 4px;
  }
</style>
