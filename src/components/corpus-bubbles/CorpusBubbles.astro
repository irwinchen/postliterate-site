---
/**
 * CorpusBubbles — d3 zoomable circle-pack of AI pre-training data.
 *
 * Reference: https://observablehq.com/@d3/zoomable-circle-packing
 *
 * The full hierarchy renders at once (root + 11 categories + ~24 leaves).
 * Click a bubble → it becomes the focus and the inner `<g>` zooms to fit
 * the focus circle into the bubble region with a single cubic ease on a
 * `view = [cx, cy, w]` interpolation. Click the focus or the SVG
 * background → zoom up to the parent. A sidenote panel on the right swaps
 * its content per focus.
 *
 * Layout JSON is generated by `npm run bubbles:build`
 * (src/lib/corpus-bubbles/build.mjs).
 */
import tree from '../../../public/corpus-bubbles/tree.json';

const { canvas, region, rootId, nodes } = tree;
const [vx, vy, vw, vh] = canvas.viewBox;

const TOTAL_PCT = nodes
  .filter((n) => n.depth === 1)
  .reduce((s, n) => s + (n.value || 0), 0);

// Sidenote-style panel coordinates (in SVG userspace; foreignObject scales
// with the SVG). Sits right of the bubble region (which lives left-of-
// center per build.mjs's REGION_CX). PANEL_H is just the foreignObject
// budget — the panel itself sizes to content.
const PANEL_X = 1080;
const PANEL_Y = 130;
const PANEL_W = 420;
const PANEL_H = 700;

// Connector line: anchored at panel left-edge; the other endpoint and the
// dasharray/dashoffset are recomputed per focus by `positionConnector` in
// the script. Static x1 just needs to be PANEL_X — y1, x2, y2 are written
// by JS each focus.
const CONNECTOR_X1 = PANEL_X;

// Render order: parents before children so children paint on top. d3
// `descendants()` already returns DFS order; we keep that.
---

<div
  class="cb-wrap"
  data-component="corpus-bubbles"
  data-region-cx={region.cx}
  data-region-cy={region.cy}
  data-region-d={region.diameter}
  data-root-id={rootId}
>
  <header class="cb-header">
    <h1 class="cb-title">What does an AI model actually train on?</h1>
    <p class="cb-caveat">
      Illustrative composite — no single model uses exactly this mix.
    </p>
  </header>

  <div class="cb-stage">
    <svg
      class="cb-svg"
      viewBox={`${vx} ${vy} ${vw} ${vh}`}
      preserveAspectRatio="xMidYMid meet"
      role="img"
      aria-label="Pre-training corpus visualized as a zoomable cluster of bubbles, each sized by its share of training tokens"
    >
      <!-- Feathered circle edges signal that these are rough estimates,
           not precise percentages. Applied per-circle (not per-group) so
           labels stay crisp. -->
      <defs>
        <filter
          id="cb-feather"
          x="-15%"
          y="-15%"
          width="130%"
          height="130%"
          color-interpolation-filters="sRGB"
        >
          <feGaussianBlur stdDeviation="3.5" />
        </filter>
      </defs>
      <!-- Zoom layer: transform applied on click to scale the focus circle
           into the bubble region. -->
      <g class="cb-zoom-layer">
        {nodes.map((n, i) => {
          // Per-bubble breathing offsets — duration spread 4.4–6.4s, delay
          // negative so each bubble starts mid-breath and the cluster feels
          // alive from frame 0. Deterministic from index so the layout is
          // stable across renders.
          const breatheDur = (4.4 + ((i * 0.37) % 2)).toFixed(2);
          const breatheDelay = -((i * 1.13) % 4).toFixed(2);
          return (
          <g
            class={`cb-node cb-depth-${n.depth}`}
            data-id={n.id}
            data-parent-id={n.parentId || ''}
            data-depth={n.depth}
            data-hidden={n.depth >= 2 ? 'true' : undefined}
            tabindex={n.depth === 0 ? undefined : '0'}
            role={n.depth === 0 ? undefined : 'button'}
            style={`--cb-breathe-dur: ${breatheDur}s; --cb-breathe-delay: ${breatheDelay}s`}
            aria-label={
              n.depth === 0
                ? 'Whole corpus'
                : `${n.label} — ${n.value}% of pre-training tokens`
            }
          >
            <circle
              cx={n.x}
              cy={n.y}
              r={n.r}
              fill={n.color || '#888'}
              class="cb-node-fill"
              vector-effect="non-scaling-stroke"
            />
            {n.depth > 0 && n.label && (
              <text
                x={n.x}
                y={n.y}
                text-anchor="middle"
                dominant-baseline="middle"
                font-family="Outfit, system-ui, sans-serif"
                font-weight="500"
                font-size="9.5"
                fill="#fff"
                class="cb-node-label"
              >
                {n.label}
              </text>
            )}
            {n.depth === 0 && (
              <text
                x={n.x}
                y={n.y - n.r + 38}
                text-anchor="middle"
                dominant-baseline="middle"
                font-family="Outfit, system-ui, sans-serif"
                font-weight="500"
                font-size="16"
                letter-spacing="0.5"
                fill="var(--text-tertiary)"
                class="cb-container-label"
              >
                The Corpus
              </text>
            )}
          </g>
          );
        })}
      </g>

      <!-- Connector line from panel to focused bubble. y1, x2, y2,
           dasharray, and dashoffset are all written by `positionConnector`
           in the script after each zoom completes. Visibility is gated by
           opacity (driven by `data-line-on` on the wrap) so stale endpoints
           from a previous focus can never paint between zooms. -->
      <line
        class="cb-connector"
        x1={CONNECTOR_X1}
        y1="0"
        x2={CONNECTOR_X1}
        y2="0"
        stroke-linecap="round"
        vector-effect="non-scaling-stroke"
      />

      <!-- Sidenote panel — outside the zoom layer so it stays put. -->
      <foreignObject
        class="cb-panel-wrap"
        x={PANEL_X}
        y={PANEL_Y}
        width={PANEL_W}
        height={PANEL_H}
      >
        <div xmlns="http://www.w3.org/1999/xhtml" class="cb-panel" tabindex="-1">
          <p class="cb-panel-hint">Click any bubble to zoom in. Click outside or on the bubble again to zoom back out.</p>
          <h2 class="cb-panel-title" hidden></h2>
          <p class="cb-panel-pct" hidden></p>
          <p class="cb-panel-desc" hidden></p>
          <ul class="cb-panel-bullets"></ul>
          <figure class="cb-panel-screenshot" hidden>
            <img class="cb-panel-screenshot-img" src="" alt="" loading="lazy" />
            <figcaption class="cb-panel-screenshot-caption"></figcaption>
          </figure>
          <div class="cb-panel-unknown" hidden>
            <p class="cb-panel-redacted">████████████████████████</p>
            <p class="cb-panel-redacted">██████ ████████</p>
            <p class="cb-panel-redacted-note">
              Transparency score: 40/100 (FMTI 2025 average)
            </p>
          </div>
        </div>
      </foreignObject>
    </svg>
  </div>

  <footer class="cb-sources">
    <span class="cb-sources-label">Sources:</span>
    <span>The Pile (EleutherAI) [SECONDARY-ONLY]</span> ·
    <span>Dolma v1.7 (AI2) [SECONDARY-ONLY]</span> ·
    <span>Llama 3.1 Tech Report (Meta) [PRIMARY-PARTIAL]</span> ·
    <span>FMTI 2025 (Stanford HAI) [SECONDARY-ONLY]</span>
  </footer>
</div>

<style>
  .cb-wrap {
    position: relative;
    inline-size: 100%;
    block-size: 100%;
    color: var(--text);
    font-family: 'Outfit', system-ui, sans-serif;
  }

  /* Header overlays the SVG in the top-left corner. `pointer-events: none`
     lets the chart catch clicks underneath the header text. */
  .cb-header {
    position: absolute;
    inset-block-start: 24px;
    inset-inline-start: clamp(16px, 4vw, 48px);
    inset-inline-end: clamp(16px, 4vw, 48px);
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 16px;
    pointer-events: none;
  }
  .cb-title {
    font-size: clamp(20px, 2.2vw, 30px);
    font-weight: 500;
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .cb-caveat {
    font-size: 12px;
    color: var(--text-tertiary);
    font-style: italic;
    margin: 0;
  }

  /* Stage = full-viewport SVG canvas. */
  .cb-stage {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .cb-svg {
    inline-size: 100%;
    block-size: 100%;
    display: block;
    cursor: default;
    outline: none;
  }

  /* Zoom layer — transform set inline by JS each animation frame. */
  .cb-zoom-layer {
    transform-origin: 0 0;
    transform-box: view-box;
    will-change: transform;
  }

  /* Each node = circle (+ label). Click handlers on the group via JS.
     Per-node visibility is toggled via `data-hidden` set by JS — d2 nodes
     are hidden at root focus and fade in as you zoom into their parent. */
  .cb-node {
    cursor: pointer;
    transition: opacity 250ms ease-out;
    outline: none; /* keyboard focus is shown via the white stroke below */
  }
  .cb-node[data-hidden='true'] {
    opacity: 0;
    pointer-events: none;
  }
  .cb-node-fill {
    stroke-width: 1;
    transition:
      stroke-width 120ms ease-out,
      opacity 200ms ease-out;
    /* Feathered edge — stdDeviation in user units, so the blur scales with
       zoom (deeper zoom shows softer edges, which reinforces "imprecise"). */
    filter: url(#cb-feather);
    /* Subtle breathing. Per-bubble duration + delay are set inline so the
       cluster doesn't pulse in unison. transform-box: fill-box keeps each
       scale centered on its own circle. */
    transform-box: fill-box;
    transform-origin: center;
    animation: cb-breathe var(--cb-breathe-dur, 5.5s) ease-in-out infinite;
    animation-delay: var(--cb-breathe-delay, 0s);
  }
  @keyframes cb-breathe {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.022);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .cb-node-fill {
      animation: none;
    }
  }

  /* When zoomed into a category, fade the focused d1 itself so the inner
     children read more strongly. JS sets data-focus on the focused node. */
  .cb-wrap[data-focus-depth='1'] .cb-node[data-focus='true'] > .cb-node-fill {
    opacity: 0.5;
  }

  /* Hover on an inner child at zoomed-in view fades every other visible
     bubble (siblings + the container d1). `:has()` is supported in all
     evergreen browsers as of 2023. */
  .cb-wrap[data-focus-depth='1']
    .cb-zoom-layer:has(.cb-node[data-depth='2']:hover)
    .cb-node:not(:hover)
    > .cb-node-fill {
    opacity: 0.3;
  }
  /* Don't feather the root container — it's a thin stroked outline that
     would just look fuzzy. */
  .cb-depth-0 > .cb-node-fill {
    filter: none;
  }
  .cb-depth-1 > .cb-node-fill {
    stroke: rgba(255, 255, 255, 0.4);
  }
  .cb-depth-2 > .cb-node-fill {
    stroke: #fff;
    stroke-width: 1.25;
  }
  .cb-node:hover > .cb-node-fill,
  .cb-node:focus-visible > .cb-node-fill {
    stroke: #fff;
    stroke-width: 2;
  }
  /* Outer container: a subtly-tinted disc that distinguishes the cluster
     area from the page background in both themes. Both colors come from
     page-level CSS variables so the dark-theme override (defined on the
     unscoped <html>) actually reaches them. */
  .cb-depth-0 > .cb-node-fill {
    fill: var(--container-fill);
    stroke: var(--container-stroke);
    stroke-width: 1.5;
  }

  /* Labels — font-size/fill are SVG presentation attributes (set on the
     element, not via CSS) because Astro's scoped class selectors don't
     reliably win on SVG <text> in this codebase. JS updates font-size each
     animation frame to counter-scale the zoom so labels stay near 9.5 px
     on screen at every level. Hidden by default; JS toggles `data-label-on`
     on the parent group for the focus's children. */
  .cb-node-label {
    pointer-events: none;
    opacity: 0;
    transition: opacity 200ms ease-out;
  }
  .cb-node[data-label-on='true'] > .cb-node-label {
    opacity: 1;
  }

  /* Connector line from the panel's left edge to the focused bubble's
     circumference. `positionConnector` writes y1, x2, y2, stroke-dasharray,
     and stroke-dashoffset (= length, hidden) per focus. Visibility is
     gated by opacity so stale endpoints can never paint between zooms.
     Stroke is neutral so it stays visible on top of the focused bubble. */
  .cb-connector {
    fill: none;
    stroke: var(--text-secondary);
    stroke-width: 1.25;
    pointer-events: none;
    opacity: 0;
  }
  .cb-wrap[data-line-on='true'] .cb-connector {
    opacity: 0.7;
    stroke-dashoffset: 0;
    transition: stroke-dashoffset 450ms ease-out;
  }

  /* Sidenote panel — sits right of the bubble region, no background, thin
     accent left border in the focus's color. */
  .cb-panel-wrap {
    overflow: visible;
    pointer-events: none; /* let zoom layer get clicks except where text is */
  }
  .cb-panel {
    box-sizing: border-box;
    /* Semi-opaque background tinted to the page color so text stays
       readable when bubbles zoom in behind it. `--panel-bg` is defined on
       :root in the page styles so it survives Astro's CSS scoping when
       the dark-mode override needs to reach the unscoped <html>. */
    background: var(--panel-bg, rgba(243, 239, 225, 0.88));
    /* Accent border picks up the focus color from the same variable as
       the connector line. */
    border-inline-start: 2px solid
      var(--cb-focus-color, var(--text-tertiary));
    /* Panel height auto-fits content, so the accent border only spans the
       text it labels. The foreignObject just defines the max budget. */
    block-size: auto;
    padding-block: 12px 14px;
    padding-inline: 14px 12px;
    font-family: 'Outfit', system-ui, sans-serif;
    color: var(--text-tertiary);
    pointer-events: auto;
    outline: none;
  }
  .cb-panel-hint {
    font-size: 11px;
    color: var(--text-tertiary);
    line-height: 1.5;
    margin: 0;
    font-style: italic;
  }
  .cb-panel-title {
    font-size: 15px;
    font-weight: 600;
    margin: 0 0 3px 0;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--text);
  }
  .cb-panel-pct {
    font-size: 9.5px;
    color: var(--text-tertiary);
    margin: 0 0 8px 0;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .cb-panel-desc {
    font-size: 11.5px;
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 0 0 8px 0;
  }
  .cb-panel-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 8px 0;
    /* Mono evokes "data" — each bullet typically cites a dataset or stat. */
    font-family: 'Sono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10px;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: var(--text-secondary);
  }
  .cb-panel-bullets li {
    padding-inline-start: 10px;
    position: relative;
    margin-block-end: 4px;
  }
  .cb-panel-bullets li::before {
    content: '·';
    position: absolute;
    inset-inline-start: 0;
    inset-block-start: -3px;
    font-weight: 700;
    color: currentColor;
  }
  .cb-panel-screenshot {
    margin: 6px 0 0 0;
  }
  .cb-panel-screenshot-img {
    inline-size: 100%;
    block-size: auto;
    display: block;
    border: 1px solid var(--border-subtle);
  }
  .cb-panel-screenshot-caption {
    font-size: 9.5px;
    color: var(--text-tertiary);
    margin-block-start: 4px;
    font-style: italic;
    line-height: 1.35;
  }
  .cb-panel-redacted {
    font-family: 'Sono', monospace;
    color: var(--text-tertiary);
    opacity: 0.55;
    letter-spacing: -0.05em;
    margin: 0 0 4px 0;
    font-size: 11px;
  }
  .cb-panel-redacted-note {
    font-size: 9.5px;
    color: var(--text-tertiary);
    margin-block-start: 8px;
    font-style: italic;
  }

  /* Panel reveals via a swift left-to-right wipe. The default state is
     fully clipped from the right; JS adds `data-panel-on` after the zoom
     completes and the new content is in the DOM. */
  .cb-panel {
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0ms linear; /* hide is instant */
  }
  .cb-wrap[data-panel-on='true'] .cb-panel {
    clip-path: inset(0 0 0 0);
    transition: clip-path 350ms cubic-bezier(0.55, 0, 0.55, 1);
  }

  /* Footer overlays the bottom of the SVG. */
  .cb-sources {
    position: absolute;
    inset-block-end: 8px;
    inset-inline: 0;
    z-index: 2;
    font-size: 11px;
    color: var(--text-tertiary);
    text-align: center;
    padding-block: 8px;
    pointer-events: none;
  }
  .cb-sources-label {
    font-weight: 600;
    margin-inline-end: 4px;
  }
</style>

<script define:vars={{ tree, panelX: PANEL_X, panelY: PANEL_Y }}>
  (function initCorpusBubbles() {
    const wrap = document.querySelector('[data-component="corpus-bubbles"]');
    if (!wrap) return;

    const svg = wrap.querySelector('.cb-svg');
    const zoomLayer = wrap.querySelector('.cb-zoom-layer');
    const panel = wrap.querySelector('.cb-panel');
    const panelHint = wrap.querySelector('.cb-panel-hint');
    const panelTitle = wrap.querySelector('.cb-panel-title');
    const panelPct = wrap.querySelector('.cb-panel-pct');
    const panelDesc = wrap.querySelector('.cb-panel-desc');
    const panelBullets = wrap.querySelector('.cb-panel-bullets');
    const panelScreenshot = wrap.querySelector('.cb-panel-screenshot');
    const panelScreenshotImg = wrap.querySelector('.cb-panel-screenshot-img');
    const panelScreenshotCaption = wrap.querySelector(
      '.cb-panel-screenshot-caption',
    );
    const panelUnknown = wrap.querySelector('.cb-panel-unknown');

    const REGION_CX = +wrap.dataset.regionCx;
    const REGION_CY = +wrap.dataset.regionCy;
    const REGION_D = +wrap.dataset.regionD;
    const ROOT_ID = wrap.dataset.rootId;
    const PANEL_X = +panelX;
    const PANEL_Y = +panelY;
    const connector = wrap.querySelector('.cb-connector');

    const nodesById = Object.create(null);
    for (const n of tree.nodes) nodesById[n.id] = n;

    const nodeEls = new Map();
    for (const el of wrap.querySelectorAll('.cb-node')) {
      nodeEls.set(el.dataset.id, el);
    }
    const labelEls = Array.from(wrap.querySelectorAll('.cb-node-label'));

    // Counter-scaled label sizes in SVG units. Children get the small
    // size; a focused leaf gets the larger size so its label reads
    // sensibly inside its screen-filling bubble.
    const LABEL_BASE_PX = 9.5;
    const FOCUS_LEAF_LABEL_PX = 18;

    const reducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    );

    // -- View state. `view = [cx, cy, w]` matches d3-interpolate-zoom. --
    function focusToView(node) {
      // 5% padding so the focus circle doesn't kiss the region edges.
      return [node.x, node.y, node.r * 2 * 1.05];
    }

    function applyView(view) {
      const k = REGION_D / view[2];
      const tx = REGION_CX - view[0] * k;
      const ty = REGION_CY - view[1] * k;
      zoomLayer.style.transform = `translate(${tx}px, ${ty}px) scale(${k})`;
      // Counter-scale labels so they read at LABEL_BASE_PX on screen at
      // any zoom. Set as an SVG attribute (in SVG user units, which the
      // zoom transform then rescales — net effect: constant px on screen).
      // The focus's own label (when it's a leaf — see setLabelVisibility)
      // gets a larger size so it reads inside the screen-filling bubble.
      const childSize = (LABEL_BASE_PX / k).toFixed(3);
      const focusSize = (FOCUS_LEAF_LABEL_PX / k).toFixed(3);
      for (const lbl of labelEls) {
        const isFocus = lbl.parentNode.dataset.id === focusId;
        lbl.setAttribute('font-size', isFocus ? focusSize : childSize);
      }
    }

    // Cubic ease-in-out — same shape d3 uses by default for transitions.
    function ease(t) {
      return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
    }

    let currentView = focusToView(nodesById[ROOT_ID]);
    let focusId = ROOT_ID;
    let rafId = 0;

    function animateZoom(targetView, duration, onComplete) {
      cancelAnimationFrame(rafId);
      if (reducedMotion.matches || duration === 0) {
        currentView = targetView.slice();
        applyView(currentView);
        onComplete && onComplete();
        return;
      }
      const startView = currentView.slice();
      const start = performance.now();
      function tick(now) {
        const t = Math.min(1, (now - start) / duration);
        const e = ease(t);
        const v = startView.map((s, i) => s + (targetView[i] - s) * e);
        applyView(v);
        if (t < 1) {
          rafId = requestAnimationFrame(tick);
        } else {
          currentView = targetView.slice();
          onComplete && onComplete();
        }
      }
      rafId = requestAnimationFrame(tick);
    }

    // Place the connector from the panel's vertical midpoint, slanted
    // toward the focused bubble's center, and stop at the bubble's
    // circumference so the line never paints over the circle. CSS px
    // inside the foreignObject map 1:1 to SVG user units, so
    // panel.offsetHeight reads directly.
    function positionConnector() {
      const yMid = PANEL_Y + panel.offsetHeight / 2;
      const r = REGION_D / 2 / 1.05; // focus bubble's display radius
      const dx = REGION_CX - PANEL_X;
      const dy = REGION_CY - yMid;
      const dist = Math.hypot(dx, dy);
      // Walk from the panel toward the center; stop at the circumference.
      const t = dist > r ? (dist - r) / dist : 0;
      const xEnd = PANEL_X + dx * t;
      const yEnd = yMid + dy * t;
      const len = Math.hypot(xEnd - PANEL_X, yEnd - yMid);
      connector.setAttribute('y1', yMid);
      connector.setAttribute('x2', xEnd);
      connector.setAttribute('y2', yEnd);
      // Dasharray = line length (one full dash, no gap). Initial dashoffset
      // = length (line hidden); when `data-line-on` is set, CSS overrides
      // dashoffset to 0 with a 450ms transition, drawing the line.
      connector.setAttribute('stroke-dasharray', len);
      connector.setAttribute('stroke-dashoffset', len);
    }

    function setLabelVisibility(focusId) {
      // Show labels of focus's children. If the focus is a leaf (no
      // children), show the focus's own label instead — otherwise the
      // screen-filling bubble would be unlabeled.
      const focus = nodesById[focusId];
      const focusIsLeaf = !focus.childIds || focus.childIds.length === 0;
      for (const [id, el] of nodeEls) {
        const n = nodesById[id];
        const on = focusIsLeaf ? n.id === focusId : n.parentId === focusId;
        if (on) el.setAttribute('data-label-on', 'true');
        else el.removeAttribute('data-label-on');
      }
    }

    // Show only nodes that are "in scope" for the current focus. Hidden
    // nodes also have pointer-events: none (via CSS), so off-screen
    // bubbles can't intercept clicks meant for the SVG background — without
    // this, the inverse zoom transform makes some sibling bubble's hit area
    // land under any background click, hijacking the zoom-out.
    //
    //   focus = root → 11 categories visible, d2 hidden.
    //   focus = d1   → that d1 + its children visible; everything else hidden.
    //   focus = d2   → only the leaf itself visible.
    function setNodeVisibility(focusId) {
      const focus = nodesById[focusId];
      wrap.setAttribute('data-focus-depth', String(focus.depth));
      for (const [id, el] of nodeEls) {
        const n = nodesById[id];
        let visible;
        if (focus.depth === 0) {
          visible = n.depth <= 1;
        } else if (focus.depth === 1) {
          visible = id === focusId || n.parentId === focusId;
        } else {
          visible = id === focusId;
        }
        if (visible) el.removeAttribute('data-hidden');
        else el.setAttribute('data-hidden', 'true');
        if (id === focusId) el.setAttribute('data-focus', 'true');
        else el.removeAttribute('data-focus');
      }
    }

    function updatePanel(node) {
      // Bullet `::before` glyph still uses currentColor; keep the inline
      // color in sync with the focus so its dot picks up the accent.
      panel.style.color = node.color || 'var(--text-tertiary)';

      const isRoot = node.depth === 0;
      panelHint.hidden = !isRoot;
      panelTitle.hidden = isRoot;
      panelPct.hidden = isRoot;
      panelDesc.hidden = isRoot || !node.description;
      panelBullets.hidden = isRoot || !(node.bullets && node.bullets.length);
      panelScreenshot.hidden = isRoot || !node.screenshot;
      panelUnknown.hidden = isRoot || !node.isUnknown;

      if (!isRoot) {
        panelTitle.textContent = node.label;
        panelPct.textContent = `${node.value}% of pre-training tokens`;
        panelDesc.textContent = node.description || '';

        panelBullets.innerHTML = '';
        for (const b of node.bullets || []) {
          const li = document.createElement('li');
          li.textContent = b;
          panelBullets.appendChild(li);
        }

        if (node.screenshot) {
          panelScreenshotImg.src = node.screenshot;
          panelScreenshotImg.alt = node.screenshotCaption || node.label;
          panelScreenshotCaption.textContent = node.screenshotCaption || '';
        }
      }
    }

    function setFocus(id, opts = {}) {
      const node = nodesById[id];
      if (!node) return;
      focusId = id;

      // Hide panel + connector before zoom so the user sees the bubble fly
      // first; both reappear once the zoom settles. Removing the attributes
      // is enough — CSS handles the instant-hide via 0ms transition.
      wrap.removeAttribute('data-panel-on');
      wrap.removeAttribute('data-line-on');

      // Update labels + node visibility immediately so they animate
      // alongside the zoom.
      setLabelVisibility(id);
      setNodeVisibility(id);

      // Stash the focus color for the connector stroke + panel border.
      wrap.style.setProperty(
        '--cb-focus-color',
        node.color || 'var(--text-tertiary)',
      );

      animateZoom(focusToView(node), opts.duration ?? 750, () => {
        // Swap content + reposition the connector while the panel is
        // still hidden. The single rAF gap below lets the browser register
        // the hidden state before the reveal transition starts — without
        // it, the content swap and the reveal land in one paint and the
        // wipe is skipped.
        updatePanel(node);
        positionConnector();
        requestAnimationFrame(() => {
          wrap.setAttribute('data-panel-on', 'true');
          if (node.depth > 0) wrap.setAttribute('data-line-on', 'true');
        });
      });
    }

    // -- Wire interactions ---------------------------------------------------

    for (const [id, el] of nodeEls) {
      // Don't make the root clickable as a "node" — clicks on the root
      // background should zoom out, which the wrap handler covers. Skip
      // the root from per-node listeners.
      if (id === ROOT_ID) continue;

      el.addEventListener('click', (e) => {
        e.stopPropagation();
        if (focusId === id) {
          // Clicking the focus zooms out one level.
          const parent = nodesById[id].parentId;
          if (parent) setFocus(parent);
        } else {
          setFocus(id);
        }
      });
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          if (focusId === id) {
            const parent = nodesById[id].parentId;
            if (parent) setFocus(parent);
          } else {
            setFocus(id);
          }
        }
      });
    }

    // Wrap-level handler — anything that wasn't absorbed by a node handler
    // (and isn't on the panel) zooms out one level.
    wrap.addEventListener('click', (e) => {
      if (e.target.closest('.cb-panel')) return;
      const parent = nodesById[focusId].parentId;
      if (parent) setFocus(parent);
    });

    // ESC zooms out one level too.
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const parent = nodesById[focusId].parentId;
      if (parent) setFocus(parent);
    });

    // -- Initial render ------------------------------------------------------

    // Apply the initial view immediately, then the panel + labels +
    // visibility (so d2 starts hidden at root view). Trigger the panel
    // wipe on the next frame so it animates rather than appearing already
    // revealed. No connector at root.
    applyView(currentView);
    setLabelVisibility(focusId);
    setNodeVisibility(focusId);
    updatePanel(nodesById[focusId]);
    positionConnector();
    requestAnimationFrame(() => {
      wrap.setAttribute('data-panel-on', 'true');
    });
  })();
</script>
