---
/**
 * CorpusBubbles — bubble-pack visualization of AI pre-training data.
 *
 * Phase 4: modal drill-in with crossfade. Clicking a bubble dims and blurs
 * the root cluster and reveals a modal layer with the parent bubble scaled
 * up at canvas center, its children packed inside, and a panel card with
 * description/bullets/screenshot. Close via × button or ESC.
 *
 * Phase 5 will add the rubbery scale animation on top of this crossfade.
 *
 * Layout JSON is generated by `npm run bubbles:build`
 * (src/lib/corpus-bubbles/build.mjs).
 */
import rootLayout from '../../../public/corpus-bubbles/root.json';

// Eager-load all 11 drill-in JSONs so they ship with the page bundle. The
// total size is ~50 KB, smaller than a single typical screenshot.
const drillInModules = import.meta.glob(
  '../../../public/corpus-bubbles/*.json',
  { eager: true },
);
const drillIns = {};
for (const [path, mod] of Object.entries(drillInModules)) {
  const name = path.split('/').pop().replace('.json', '');
  if (name === 'root') continue;
  drillIns[name] = mod.default || mod;
}

const { canvas, container, cells } = rootLayout;
const [vx, vy, vw, vh] = canvas.viewBox;

const TOTAL = cells.reduce((s, c) => s + c.value, 0);
const pct = (v) => ((v / TOTAL) * 100).toFixed(1) + '%';

function labelMode(r) {
  if (r >= 50) return 'full';
  if (r >= 28) return 'label';
  return 'none';
}

// Panel position in canvas coordinates. Sits on the right of the canvas.
const PANEL_X = 730;
const PANEL_Y = 70;
const PANEL_W = 260;
const PANEL_H = 560;
---

<div class="cb-wrap" data-component="corpus-bubbles" data-modal-open="">
  <header class="cb-header">
    <h1 class="cb-title">What does an AI model actually train on?</h1>
    <p class="cb-caveat">
      Illustrative composite — no single model uses exactly this mix.
    </p>
  </header>

  <div class="cb-stage">
    <svg
      class="cb-svg"
      viewBox={`${vx} ${vy} ${vw} ${vh}`}
      preserveAspectRatio="xMidYMid meet"
      role="img"
      aria-label="Pre-training corpus visualized as a packed cluster of bubbles, each sized by its share of training tokens"
    >
      <!-- Root layer: container circle + root bubbles. Dims and blurs when
           a modal is open. -->
      <g class="cb-root-layer">
        <circle
          cx={container.x}
          cy={container.y}
          r={container.r}
          class="cb-container"
        />
        <g class="cb-root-bubbles">
          {cells.map((c) => {
            const mode = labelMode(c.r);
            const clickable = c.hasChildren;
            return (
              <g
                class="cb-bubble"
                data-id={c.id}
                data-clickable={clickable ? 'true' : 'false'}
                role={clickable ? 'button' : undefined}
                tabindex={clickable ? '0' : undefined}
                aria-label={
                  clickable
                    ? `${c.label} — ${pct(c.value)}, click to drill in`
                    : `${c.label} — ${pct(c.value)}`
                }
              >
                <circle
                  cx={c.x}
                  cy={c.y}
                  r={c.r}
                  fill={c.color || '#888'}
                  class="cb-bubble-fill"
                />
                {mode !== 'none' && (
                  <text
                    x={c.x}
                    y={mode === 'full' ? c.y - 4 : c.y}
                    text-anchor="middle"
                    dominant-baseline="middle"
                    class="cb-bubble-label"
                  >
                    {c.label}
                  </text>
                )}
                {mode === 'full' && (
                  <text
                    x={c.x}
                    y={c.y + 16}
                    text-anchor="middle"
                    dominant-baseline="middle"
                    class="cb-bubble-pct"
                  >
                    {pct(c.value)}
                  </text>
                )}
              </g>
            );
          })}
        </g>
      </g>

      <!-- Modal layer. Populated by JS on drill-in. -->
      <g class="cb-modal-layer" aria-hidden="true">
        <circle class="cb-modal-parent" cx="0" cy="0" r="0" fill="#888" />
        <g class="cb-modal-children"></g>

        <foreignObject
          class="cb-modal-panel-wrap"
          x={PANEL_X}
          y={PANEL_Y}
          width={PANEL_W}
          height={PANEL_H}
        >
          <div xmlns="http://www.w3.org/1999/xhtml" class="cb-modal-panel">
            <button class="cb-modal-close" aria-label="Close drill-in">×</button>
            <div class="cb-modal-swatch"></div>
            <h2 class="cb-modal-title"></h2>
            <p class="cb-modal-pct"></p>
            <p class="cb-modal-desc"></p>
            <ul class="cb-modal-bullets"></ul>
            <figure class="cb-modal-screenshot" hidden>
              <img class="cb-modal-screenshot-img" src="" alt="" loading="lazy" />
              <figcaption class="cb-modal-screenshot-caption"></figcaption>
            </figure>
            <div class="cb-modal-unknown" hidden>
              <p class="cb-modal-redacted">████████████████████████</p>
              <p class="cb-modal-redacted">██████ ████████</p>
              <p class="cb-modal-redacted-note">
                Transparency score: 40/100 (FMTI 2025 average)
              </p>
            </div>
          </div>
        </foreignObject>
      </g>
    </svg>
  </div>

  <footer class="cb-sources">
    <span class="cb-sources-label">Sources:</span>
    <span>The Pile (EleutherAI) [SECONDARY-ONLY]</span> ·
    <span>Dolma v1.7 (AI2) [SECONDARY-ONLY]</span> ·
    <span>Llama 3.1 Tech Report (Meta) [PRIMARY-PARTIAL]</span> ·
    <span>FMTI 2025 (Stanford HAI) [SECONDARY-ONLY]</span>
  </footer>
</div>

<style>
  .cb-wrap {
    display: grid;
    grid-template-rows: auto 1fr auto;
    block-size: 100%;
    padding-block: 20px;
    padding-inline: clamp(16px, 4vw, 48px);
    row-gap: 8px;
    color: var(--text);
    font-family: 'Outfit', system-ui, sans-serif;
  }

  .cb-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 16px;
  }
  .cb-title {
    font-size: clamp(20px, 2.2vw, 30px);
    font-weight: 500;
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .cb-caveat {
    font-size: 12px;
    color: var(--text-tertiary);
    font-style: italic;
    margin: 0;
  }

  .cb-stage {
    display: grid;
    place-items: center;
    min-block-size: 0;
    min-inline-size: 0;
    overflow: hidden;
  }
  .cb-svg {
    inline-size: 100%;
    block-size: 100%;
    max-inline-size: 1200px;
    display: block;
  }

  .cb-container {
    fill: rgba(0, 0, 0, 0.03);
    stroke: rgba(0, 0, 0, 0.15);
    stroke-width: 1.5;
    pointer-events: none;
  }
  [data-theme='dark'] .cb-container {
    fill: rgba(255, 255, 255, 0.03);
    stroke: rgba(255, 255, 255, 0.15);
  }

  .cb-bubble-fill {
    stroke: var(--background);
    stroke-width: 2;
  }
  .cb-bubble-label {
    font-size: clamp(11px, 1.05vw, 15px);
    fill: #fff;
    pointer-events: none;
    font-weight: 500;
    font-family: 'Outfit', system-ui, sans-serif;
  }
  .cb-bubble-pct {
    font-size: clamp(9px, 0.85vw, 12px);
    fill: rgba(255, 255, 255, 0.78);
    pointer-events: none;
    font-weight: 400;
    font-family: 'Outfit', system-ui, sans-serif;
  }
  .cb-bubble[data-clickable='true'] {
    cursor: pointer;
  }
  .cb-bubble[data-clickable='true']:hover .cb-bubble-fill,
  .cb-bubble[data-clickable='true']:focus-visible .cb-bubble-fill {
    stroke: rgba(255, 255, 255, 0.9);
    stroke-width: 3;
  }

  /* Root layer crossfade when a modal opens. */
  .cb-root-layer {
    transition:
      filter 250ms ease-out,
      opacity 250ms ease-out;
    transform-origin: center;
  }
  .cb-wrap[data-modal-open]:not([data-modal-open='']) .cb-root-layer {
    filter: grayscale(1) blur(6px) brightness(1.1);
    opacity: 0.18;
    pointer-events: none;
  }

  /* Modal layer — hidden by default, fades in when a drill-in is active. */
  .cb-modal-layer {
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 250ms ease-out,
      visibility 0s linear 250ms;
  }
  .cb-wrap[data-modal-open]:not([data-modal-open='']) .cb-modal-layer {
    opacity: 1;
    visibility: visible;
    transition:
      opacity 250ms ease-out,
      visibility 0s linear 0s;
  }

  .cb-modal-parent {
    stroke: rgba(255, 255, 255, 0.4);
    stroke-width: 1.5;
  }
  .cb-modal-children .cb-modal-child-fill {
    stroke: rgba(255, 255, 255, 0.5);
    stroke-width: 2;
  }
  .cb-modal-children .cb-modal-child-label {
    font-size: 13px;
    fill: #fff;
    font-weight: 500;
    pointer-events: none;
    font-family: 'Outfit', system-ui, sans-serif;
  }
  .cb-modal-children .cb-modal-child-pct {
    font-size: 11px;
    fill: rgba(255, 255, 255, 0.78);
    pointer-events: none;
    font-family: 'Outfit', system-ui, sans-serif;
  }

  /* Panel — HTML inside foreignObject, scales with the SVG. */
  .cb-modal-panel-wrap {
    overflow: visible;
  }
  .cb-modal-panel {
    box-sizing: border-box;
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid rgba(0, 0, 0, 0.1);
    block-size: 100%;
    padding: 20px 22px 22px 22px;
    font-family: 'Outfit', system-ui, sans-serif;
    color: var(--text);
    position: relative;
    overflow-y: auto;
  }
  [data-theme='dark'] .cb-modal-panel {
    background: rgba(40, 40, 40, 0.96);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .cb-modal-close {
    position: absolute;
    inset-block-start: 8px;
    inset-inline-end: 8px;
    inline-size: 28px;
    block-size: 28px;
    padding: 0;
    border: 0;
    background: rgba(0, 0, 0, 0.05);
    color: var(--text);
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    transition: background 150ms ease-out;
  }
  .cb-modal-close:hover,
  .cb-modal-close:focus-visible {
    background: rgba(0, 0, 0, 0.12);
  }
  [data-theme='dark'] .cb-modal-close {
    background: rgba(255, 255, 255, 0.08);
  }
  [data-theme='dark'] .cb-modal-close:hover,
  [data-theme='dark'] .cb-modal-close:focus-visible {
    background: rgba(255, 255, 255, 0.16);
  }

  .cb-modal-swatch {
    inline-size: 24px;
    block-size: 4px;
    margin-block-end: 10px;
    background: currentColor;
  }
  .cb-modal-title {
    font-size: 22px;
    font-weight: 600;
    margin: 0 36px 4px 0;
    letter-spacing: -0.01em;
    line-height: 1.15;
  }
  .cb-modal-pct {
    font-size: 12px;
    color: var(--text-tertiary);
    margin: 0 0 14px 0;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .cb-modal-desc {
    font-size: 14px;
    line-height: 1.45;
    color: var(--text);
    margin: 0 0 14px 0;
  }
  .cb-modal-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 14px 0;
    font-size: 12.5px;
    line-height: 1.45;
    color: var(--text-secondary);
  }
  .cb-modal-bullets li {
    padding-inline-start: 14px;
    position: relative;
    margin-block-end: 6px;
  }
  .cb-modal-bullets li::before {
    content: '·';
    position: absolute;
    inset-inline-start: 4px;
    inset-block-start: -2px;
    font-weight: 700;
    color: currentColor;
  }
  .cb-modal-screenshot {
    margin: 0;
  }
  .cb-modal-screenshot-img {
    inline-size: 100%;
    block-size: auto;
    display: block;
    border: 1px solid rgba(0, 0, 0, 0.1);
  }
  .cb-modal-screenshot-caption {
    font-size: 11px;
    color: var(--text-tertiary);
    margin-block-start: 6px;
    font-style: italic;
    line-height: 1.35;
  }
  .cb-modal-redacted {
    font-family: 'Sono', monospace;
    color: var(--text-tertiary);
    opacity: 0.55;
    letter-spacing: -0.05em;
    margin: 0 0 4px 0;
    font-size: 12px;
  }
  .cb-modal-redacted-note {
    font-size: 11px;
    color: var(--text-tertiary);
    margin-block-start: 12px;
    font-style: italic;
  }

  .cb-sources {
    font-size: 11px;
    color: var(--text-tertiary);
    text-align: center;
    padding-block: 8px;
  }
  .cb-sources-label {
    font-weight: 600;
    margin-inline-end: 4px;
  }
</style>

<script define:vars={{ drillIns }}>
  // Client-side drill-in logic. `drillIns` is injected as an inline global
  // via Astro's `define:vars`. The script is therefore inline (not hoisted),
  // which is fine for this small handler.

  function initCorpusBubbles() {
    const wrap = document.querySelector('[data-component="corpus-bubbles"]');
    if (!wrap) return;

    const SVG_NS = 'http://www.w3.org/2000/svg';
    const modalLayer = wrap.querySelector('.cb-modal-layer');
    const parentCircle = wrap.querySelector('.cb-modal-parent');
    const childrenGroup = wrap.querySelector('.cb-modal-children');
    const panel = wrap.querySelector('.cb-modal-panel');
    const panelSwatch = wrap.querySelector('.cb-modal-swatch');
    const panelTitle = wrap.querySelector('.cb-modal-title');
    const panelPct = wrap.querySelector('.cb-modal-pct');
    const panelDesc = wrap.querySelector('.cb-modal-desc');
    const panelBullets = wrap.querySelector('.cb-modal-bullets');
    const panelScreenshot = wrap.querySelector('.cb-modal-screenshot');
    const panelScreenshotImg = wrap.querySelector('.cb-modal-screenshot-img');
    const panelScreenshotCaption = wrap.querySelector(
      '.cb-modal-screenshot-caption',
    );
    const panelUnknown = wrap.querySelector('.cb-modal-unknown');
    const closeBtn = wrap.querySelector('.cb-modal-close');

    function childPct(value, total) {
      return ((value / total) * 100).toFixed(1) + '%';
    }

    function labelModeForChild(r) {
      if (r >= 40) return 'full';
      if (r >= 22) return 'label';
      return 'none';
    }

    function openModal(id) {
      const layout = drillIns[id];
      if (!layout) return;
      const p = layout.parent;

      // Position the parent circle at its open coordinates.
      parentCircle.setAttribute('cx', p.openX);
      parentCircle.setAttribute('cy', p.openY);
      parentCircle.setAttribute('r', p.openR);
      parentCircle.setAttribute('fill', p.color || '#888');

      // Populate children.
      childrenGroup.innerHTML = '';
      const childTotal = layout.cells.reduce((s, c) => s + c.value, 0);
      for (const c of layout.cells) {
        const mode = labelModeForChild(c.r);
        const g = document.createElementNS(SVG_NS, 'g');
        g.setAttribute('class', 'cb-modal-child');
        const circle = document.createElementNS(SVG_NS, 'circle');
        circle.setAttribute('cx', c.x);
        circle.setAttribute('cy', c.y);
        circle.setAttribute('r', c.r);
        circle.setAttribute('fill', c.color || '#888');
        circle.setAttribute('class', 'cb-modal-child-fill');
        g.appendChild(circle);
        if (mode !== 'none') {
          const t = document.createElementNS(SVG_NS, 'text');
          t.setAttribute('x', c.x);
          t.setAttribute('y', mode === 'full' ? c.y - 4 : c.y);
          t.setAttribute('text-anchor', 'middle');
          t.setAttribute('dominant-baseline', 'middle');
          t.setAttribute('class', 'cb-modal-child-label');
          t.textContent = c.label;
          g.appendChild(t);
        }
        if (mode === 'full') {
          const t2 = document.createElementNS(SVG_NS, 'text');
          t2.setAttribute('x', c.x);
          t2.setAttribute('y', c.y + 16);
          t2.setAttribute('text-anchor', 'middle');
          t2.setAttribute('dominant-baseline', 'middle');
          t2.setAttribute('class', 'cb-modal-child-pct');
          t2.textContent = childPct(c.value, childTotal);
          g.appendChild(t2);
        }
        childrenGroup.appendChild(g);
      }

      // Populate panel.
      panel.style.color = p.color || '#444';
      panelTitle.textContent = p.label;
      panelPct.textContent = p.value + '% of pre-training tokens';
      panelDesc.textContent = p.description || '';

      panelBullets.innerHTML = '';
      for (const b of p.bullets || []) {
        const li = document.createElement('li');
        li.textContent = b;
        panelBullets.appendChild(li);
      }

      if (p.screenshot) {
        panelScreenshot.hidden = false;
        panelScreenshotImg.src = p.screenshot;
        panelScreenshotImg.alt = p.screenshotCaption || p.label;
        panelScreenshotCaption.textContent = p.screenshotCaption || '';
      } else {
        panelScreenshot.hidden = true;
      }

      panelUnknown.hidden = !p.isUnknown;

      // Activate modal state.
      wrap.setAttribute('data-modal-open', id);
      modalLayer.removeAttribute('aria-hidden');
      // Move focus to close button so ESC-equivalent is reachable.
      closeBtn.focus({ preventScroll: true });
    }

    function closeModal() {
      const wasOpen = wrap.getAttribute('data-modal-open');
      if (!wasOpen) return;
      wrap.setAttribute('data-modal-open', '');
      modalLayer.setAttribute('aria-hidden', 'true');
      // Restore focus to the originating bubble.
      const target = wrap.querySelector(
        `.cb-bubble[data-id="${wasOpen}"]`,
      );
      if (target) target.focus({ preventScroll: true });
    }

    // Wire bubble clicks.
    for (const bubble of wrap.querySelectorAll(
      '.cb-bubble[data-clickable="true"]',
    )) {
      const id = bubble.getAttribute('data-id');
      bubble.addEventListener('click', () => openModal(id));
      bubble.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openModal(id);
        }
      });
    }

    // Close affordances.
    closeBtn.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && wrap.getAttribute('data-modal-open')) {
        closeModal();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCorpusBubbles);
  } else {
    initCorpusBubbles();
  }
</script>
